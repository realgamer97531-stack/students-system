<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h3 class="mb-1">
      <span class="ar-only">🗂️ كل الحصص</span>
      <span class="en-only" style="display:none;">🗂️ All Sessions</span>
    </h3>
    <p class="text-muted small mb-0">
      <span class="ar-only">إدارة ومتابعة كل حصص السناتر والأونلاين</span>
      <span class="en-only" style="display:none;">Manage all center and online sessions</span>
    </p>
  </div>
  <a href="/sessions/new" class="btn btn-primary">
    <span class="ar-only">+ بدء حصة جديدة</span>
    <span class="en-only" style="display:none;">+ New Session</span>
  </a>
</div>

<div class="table-responsive bg-white rounded shadow-sm p-3">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th><span class="ar-only">السيريال</span><span class="en-only" style="display:none;">Serial</span></th>
        <th><span class="ar-only">المادة</span><span class="en-only" style="display:none;">Subject</span></th>
        <th><span class="ar-only">السنتر</span><span class="en-only" style="display:none;">Center</span></th>
        <th><span class="ar-only">الرقم النسبي</span><span class="en-only" style="display:none;">Lesson #</span></th>
        <th><span class="ar-only">التاريخ</span><span class="en-only" style="display:none;">Date</span></th>
        <th><span class="ar-only">الحالة</span><span class="en-only" style="display:none;">Status</span></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% sessions.forEach(s => { %>
        <tr class="<%= String(s.id) === String(activeSessionId) ? 'table-success' : '' %>">
          <td><strong><%= s.serial_number %></strong></td>
          <td><%= s.Subject.name %></td>
          <td><%= s.Center.name %></td>
          <td><%= s.lesson_number %></td>
          <td><%= s.session_date %></td>
          <td>
  <% if (s.status === 'cancelled') { %>
    <span class="badge" style="background:#FEE2E2; color:#B91C1C;">
      <span class="ar-only">⛔ ملغية</span>
      <span class="en-only" style="display:none;">⛔ Cancelled</span>
    </span>
  <% } else { %>
    <span class="badge" style="background:#D1FAE5; color:#047857;">
      <span class="ar-only">✓ عادية</span>
      <span class="en-only" style="display:none;">✓ Active</span>
    </span>
  <% } %>
</td>
          <td class="text-nowrap">
            <% if (String(s.id) === String(activeSessionId)) { %>
              <span class="badge bg-primary">
                <span class="ar-only">✓ الشغالة دلوقتي</span>
                <span class="en-only" style="display:none;">✓ Running</span>
              </span>
            <% } else { %>
              <form action="/sessions/<%= s.id %>/activate" method="POST" class="d-inline">
                <button type="submit" class="btn btn-sm btn-outline-primary">
                  <span class="ar-only">تفعيل</span>
                  <span class="en-only" style="display:none;">Activate</span>
                </button>
              </form>
            <% } %>
            <a href="/sessions/<%= s.id %>/report" class="btn btn-sm btn-outline-dark">
              <span class="ar-only">📊 تقرير</span>
              <span class="en-only" style="display:none;">📊 Report</span>
            </a>

            <% if (userRole === 'admin') { %>
              <% if (s.status === 'cancelled') { %>
                <form action="/sessions/<%= s.id %>/restore" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-sm btn-outline-success">
                    <span class="ar-only">إلغاء الإلغاء</span>
                    <span class="en-only" style="display:none;">Restore</span>
                  </button>
                </form>
              <% } else { %>
                <button type="button" class="btn btn-sm btn-outline-danger"
                  onclick="openCancelModal(<%= s.id %>, '<%= s.lesson_number %>', '<%= s.Subject.name %>')">
                  <span class="ar-only">🚫 إلغاء</span>
                  <span class="en-only" style="display:none;">🚫 Cancel</span>
                </button>
              <% } %>

              <button type="button" class="btn btn-sm btn-outline-secondary"
                onclick="openEditModal(<%= s.id %>, '<%= s.session_date %>')">
                <span class="ar-only">✏️ تعديل</span>
                <span class="en-only" style="display:none;">✏️ Edit</span>
              </button>

              <form action="/sessions/<%= s.id %>/delete" method="POST" class="d-inline"
                onsubmit="return confirm('متأكد من حذف الحصة دي بالكامل؟ ده غير قابل للتراجع.')">
                <button type="submit" class="btn btn-sm btn-outline-danger">
                  <span class="ar-only">🗑️ حذف</span>
                  <span class="en-only" style="display:none;">🗑️ Delete</span>
                </button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- مودال إلغاء الحصة -->
<div class="modal fade" id="cancelModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">إلغاء حصة</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="cancelForm" method="POST">
        <div class="modal-body">
          <p>هتلغي حصة رقم <strong id="cancelLessonNumber"></strong> من مادة <strong id="cancelSubjectName"></strong></p>
          <div class="form-check mb-2">
            <input class="form-check-input" type="radio" name="scope" value="single" id="scopeSingle" checked>
            <label class="form-check-label" for="scopeSingle">
              إلغاء من هذا السنتر بس (اللي اخترته)
            </label>
          </div>
          <div class="form-check">
            <input class="form-check-input" type="radio" name="scope" value="all" id="scopeAll">
            <label class="form-check-label" for="scopeAll">
              إلغاء من <strong>كل السناتر</strong> (نفس رقم الحصة في كل مكان)
            </label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">رجوع</button>
          <button type="submit" class="btn btn-danger">تأكيد الإلغاء</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- مودال تعديل تاريخ الحصة -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">تعديل تاريخ الحصة</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="editForm" method="POST">
        <div class="modal-body">
          <label class="form-label">التاريخ الصحيح</label>
          <input type="date" name="session_date" id="editDateInput" class="form-control" required>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">رجوع</button>
          <button type="submit" class="btn btn-primary">حفظ</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function openCancelModal(sessionId, lessonNumber, subjectName) {
    document.getElementById('cancelLessonNumber').textContent = lessonNumber;
    document.getElementById('cancelSubjectName').textContent = subjectName;
    document.getElementById('cancelForm').action = `/sessions/${sessionId}/cancel`;
    const modal = new bootstrap.Modal(document.getElementById('cancelModal'));
    modal.show();
  }

  function openEditModal(sessionId, currentDate) {
    document.getElementById('editDateInput').value = currentDate;
    document.getElementById('editForm').action = `/sessions/${sessionId}/edit`;
    const modal = new bootstrap.Modal(document.getElementById('editModal'));
    modal.show();
  }
</script>

<%- include('partials/footer') %>