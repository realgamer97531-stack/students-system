<%- include('partials/header') %>

<style>
  /* System-Compliant Adaptive Table Styling */
  .custom-adaptive-card {
    background: var(--sf-card-bg) !important;
    border: 1px solid var(--sf-input-border) !important;
    transition: background 0.2s, border 0.2s;
  }
  
  .custom-adaptive-table {
    background: transparent !important;
    color: var(--sf-text) !important;
    border-collapse: collapse !important;
  }

  .custom-adaptive-table thead tr {
    background: var(--sf-table-header-bg) !important;
  }

  .custom-adaptive-table th {
    color: var(--sf-text) !important;
    font-weight: 700;
    font-size: 0.85rem;
    border: 1px solid var(--sf-input-border) !important;
    padding: 12px 8px !important;
  }

  .custom-adaptive-table tbody tr {
    background: var(--sf-card-bg) !important;
    border-bottom: 1px solid var(--sf-input-border) !important;
    transition: background 0.2s;
  }

  .custom-adaptive-table tbody tr:hover {
    background: var(--sf-table-header-bg) !important;
  }

  .custom-adaptive-table td {
    color: var(--sf-text) !important;
    font-size: 0.88rem;
    vertical-align: middle;
    border: 1px solid var(--sf-input-border) !important;
    padding: 12px 8px !important;
  }

  /* Secondary data dimming for better visual hierarchy */
  .custom-adaptive-table td:nth-child(1), /* Code */
  .custom-adaptive-table td:nth-child(3), /* Student Phone */
  .custom-adaptive-table td:nth-child(4), /* Parent Phone */
  .custom-adaptive-table td:nth-child(5), /* Subject */
  .custom-adaptive-table td:nth-child(6), /* Center */
  .custom-adaptive-table td:nth-child(7), /* Price */
  .custom-adaptive-table td:nth-child(8)  /* Balance */ {
    color: var(--sf-muted) !important;
  }

  /* Primary links matching your system accents */
  .custom-adaptive-table td a {
    color: var(--sf-primary) !important;
    font-weight: 600;
    text-decoration: none;
  }
  
  [data-theme="dark"] .custom-adaptive-table td a {
    color: #60a5fa !important; /* Slightly brighter blue for dark mode contrast */
  }

  .custom-adaptive-table td a:hover {
    text-decoration: underline;
  }

  /* Badge Customizations */
  .badge.bg-success {
    background-color: rgba(20, 184, 166, 0.15) !important; /* var(--sf-accent) translucent background */
    color: var(--sf-accent) !important;
    border: 1px solid rgba(20, 184, 166, 0.3);
  }

  .badge.bg-secondary {
    background-color: var(--sf-input-border) !important;
    color: var(--sf-muted) !important;
    border: 1px solid rgba(0, 0, 0, 0.05);
  }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3>
    <span class="ar-only">قائمة الطلاب (<%= students.length %>)</span>
    <span class="en-only" style="display:none;">Students List (<%= students.length %>)</span>
  </h3>
  <div>
    <a href="/students/export?<%= new URLSearchParams(filters).toString() %>" class="btn btn-outline-success">
      <span class="ar-only">📥 تصدير إكسيل</span>
      <span class="en-only" style="display:none;">📥 Export Excel</span>
    </a>
    <a href="/students/new" class="btn btn-primary">
      <span class="ar-only">+ تسجيل طالب جديد</span>
      <span class="en-only" style="display:none;">+ Add Student</span>
    </a>
  </div>
</div>

<form method="GET" action="/students" class="row g-2 mb-3">
  <div class="col-md-4">
    <input type="text" name="search" class="form-control" 
      placeholder="🔍 بحث بالاسم، الكود، أو التليفون"
      value="<%= filters.search %>" title="Search by name, code, or phone">
  </div>
  <div class="col-md-3">
    <select name="center_id" class="form-select">
      <option value="">
        <span class="ar-only">-- كل السناتر --</span>
        <span class="en-only" style="display:none;">-- All Centers --</span>
      </option>
      <% centers.forEach(c => { %>
        <option value="<%= c.id %>" <%= String(filters.center_id) === String(c.id) ? 'selected' : '' %>>
          <%= c.name %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <select name="subject_id" class="form-select">
      <option value="">
        <span class="ar-only">-- كل المواد --</span>
        <span class="en-only" style="display:none;">-- All Subjects --</span>
      </option>
      <% subjects.forEach(s => { %>
        <option value="<%= s.id %>" <%= String(filters.subject_id) === String(s.id) ? 'selected' : '' %>>
          <%= s.name %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-2">
    <button type="submit" class="btn btn-secondary w-100">
      <span class="ar-only">بحث</span>
      <span class="en-only" style="display:none;">Search</span>
    </button>
  </div>
</form>

<div class="table-responsive custom-adaptive-card rounded shadow-sm p-3">
  <table class="table custom-adaptive-table align-middle m-0">
    <thead>
      <tr>
        <th><span class="ar-only">الكود</span><span class="en-only" style="display:none;">Code</span></th>
        <th><span class="ar-only">الاسم</span><span class="en-only" style="display:none;">Name</span></th>
        <th><span class="ar-only">تليفون الطالب</span><span class="en-only" style="display:none;">Student Phone</span></th>
        <th><span class="ar-only">تليفون ولي الأمر</span><span class="en-only" style="display:none;">Parent Phone</span></th>
        <th><span class="ar-only">المادة</span><span class="en-only" style="display:none;">Subject</span></th>
        <th><span class="ar-only">السنتر</span><span class="en-only" style="display:none;">Center</span></th>
        <th><span class="ar-only">السعر</span><span class="en-only" style="display:none;">Price</span></th>
        <th><span class="ar-only">الرصيد</span><span class="en-only" style="display:none;">Balance</span></th>
        <th><span class="ar-only">البوكليت</span><span class="en-only" style="display:none;">Booklet</span></th>
      </tr>
    </thead>
    <tbody>
      <% students.forEach(student => { %>
        <tr>
          <td><%= student.student_code %></td>
          <td><a href="/students/<%= student.id %>"><%= student.name %></a></td>
          <td><%= student.phone %></td>
          <td><%= student.parent_phone %></td>
          <td><%= student.Subject ? student.Subject.name : '-' %></td>
          <td><%= student.Center ? student.Center.name : '-' %></td>
          <td><%= student.price_per_session %> ج</td>
          <td><%= student.balance %> ج</td>
          <td>
            <% if (student.booklet_status) { %>
              <span class="badge bg-success">
                <span class="ar-only">تم الشراء</span>
                <span class="en-only" style="display:none;">Purchased</span>
              </span>
            <% } else { %>
              <span class="badge bg-secondary">
                <span class="ar-only">لسه</span>
                <span class="en-only" style="display:none;">Pending</span>
              </span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/footer') %>