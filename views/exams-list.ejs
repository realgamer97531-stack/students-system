<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3>
    <span class="ar-only">الامتحانات</span>
    <span class="en-only" style="display:none;">Exams</span>
  </h3>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h5 class="mb-3">
      <span class="ar-only">إنشاء امتحان جديد</span>
      <span class="en-only" style="display:none;">Create New Exam</span>
    </h5>
    <form action="/exams" method="POST" class="row g-2">
      <div class="col-md-3">
        <input type="text" name="name" class="form-control" 
          placeholder="اسم الامتحان" title="Exam Name" required>
      </div>
      <div class="col-md-3">
        <select name="subject_id" id="subjectSelect" class="form-select" required>
          <option value="">
            <span class="ar-only">-- المادة --</span>
            <span class="en-only" style="display:none;">-- Subject --</span>
          </option>
          <% subjects.forEach(subj => { %>
            <option value="<%= subj.id %>"><%= subj.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <select name="session_id" id="sessionSelect" class="form-select">
          <option value="">
            <span class="ar-only">-- بدون ربط بحصة معينة --</span>
            <span class="en-only" style="display:none;">-- No Session Link --</span>
          </option>
          <% allSessions.forEach(s => { %>
            <option value="<%= s.id %>" data-subject="<%= s.SubjectId %>">
              <span class="ar-only">حصة <%= s.lesson_number %> - <%= s.Center.name %> (<%= s.serial_number %>)</span>
              <span class="en-only" style="display:none;">Lesson <%= s.lesson_number %> - <%= s.Center.name %> (<%= s.serial_number %>)</span>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-1">
        <input type="number" name="max_score" class="form-control" placeholder="الدرجة" value="100" required>
      </div>
      <div class="col-md-1">
        <input type="date" name="exam_date" class="form-control" required>
      </div>
      <div class="col-md-1">
        <button type="submit" class="btn btn-primary w-100">
          <span class="ar-only">إنشاء</span>
          <span class="en-only" style="display:none;">Create</span>
        </button>
      </div>
    </form>
    <p class="text-muted small mt-2">
      <span class="ar-only">💡 لو حددت حصة، الدرجة هتظهر تلقائي جمب الواجب في ملف كل طالب حضر هذه الحصة (في أي سنتر).</span>
      <span class="en-only" style="display:none;">💡 If you link a session, the score will auto-display for all students who attended.</span>
    </p>
  </div>
</div>

<div class="table-responsive bg-white rounded shadow-sm p-3">
  <table class="table table-hover align-middle">
    <thead class="table-light">
      <tr>
        <th><span class="ar-only">الامتحان</span><span class="en-only" style="display:none;">Exam</span></th>
        <th><span class="ar-only">المادة</span><span class="en-only" style="display:none;">Subject</span></th>
        <th><span class="ar-only">الحصة المرتبطة</span><span class="en-only" style="display:none;">Linked Session</span></th>
        <th><span class="ar-only">الدرجة الكاملة</span><span class="en-only" style="display:none;">Max Score</span></th>
        <th><span class="ar-only">التاريخ</span><span class="en-only" style="display:none;">Date</span></th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% exams.forEach(exam => { %>
        <tr>
          <td><%= exam.name %></td>
          <td><%= exam.Subject.name %></td>
          <td>
            <% if (exam.Session) { %>
              <span class="ar-only">حصة <%= exam.Session.lesson_number %></span>
              <span class="en-only" style="display:none;">Lesson <%= exam.Session.lesson_number %></span>
            <% } else { %>
              <span class="text-muted">
                <span class="ar-only">مستقل</span>
                <span class="en-only" style="display:none;">Independent</span>
              </span>
            <% } %>
          </td>
          <td><%= exam.max_score %></td>
          <td><%= exam.exam_date %></td>
          <td>
            <a href="/exams/<%= exam.id %>" class="btn btn-sm btn-outline-primary">
              <span class="ar-only">رصد الدرجات</span>
              <span class="en-only" style="display:none;">Record Scores</span>
            </a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
  // إظهار حصص المادة المختارة بس في قائمة "الحصة المرتبطة"
  const subjectSelect = document.getElementById('subjectSelect');
  const sessionSelect = document.getElementById('sessionSelect');
  const allSessionOptions = Array.from(sessionSelect.options);

  subjectSelect.addEventListener('change', function () {
    const selectedSubject = this.value;
    sessionSelect.innerHTML = '';
    sessionSelect.appendChild(allSessionOptions[0]); // خيار "بدون ربط"

    allSessionOptions.forEach(opt => {
      if (opt.dataset.subject === selectedSubject) {
        sessionSelect.appendChild(opt);
      }
    });
  });
</script>

<%- include('partials/footer') %>