<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3>📋 الواجبات الأونلاين</h3>
</div>

<!-- إنشاء واجب جديد -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="mb-3">➕ إنشاء واجب جديد</h6>
    <form action="/hw/assignments/create" method="POST" class="row g-2">
      <div class="col-md-2">
        <input type="number" name="order_number" class="form-control" placeholder="رقم الواجب" required min="1">
      </div>
      <div class="col-md-3">
        <input type="text" name="title" class="form-control" placeholder="عنوان الواجب" required>
      </div>
      <div class="col-md-4">
        <textarea name="description" class="form-control" placeholder="وصف الواجب (اختياري)" rows="1"></textarea>
      </div>
      <div class="col-md-3">
        <select name="subject_id" class="form-select">
          <option value="">-- المادة --</option>
          <% subjects.forEach(s => { %><option value="<%= s.id %>"><%= s.name %></option><% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <select name="session_id" class="form-select">
          <option value="">-- ربط بحصة (اختياري) --</option>
          <% sessions.forEach(s => { %><option value="<%= s.id %>"><%= s.Subject.name %> - <%= s.Center.name %> - حصة <%= s.lesson_number %></option><% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label small">بداية التسليم</label>
        <input type="date" name="start_date" class="form-control" required>
      </div>
      <div class="col-md-2">
        <label class="form-label small">نهاية التسليم</label>
        <input type="date" name="end_date" class="form-control" required>
      </div>
      <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">إنشاء</button>
      </div>
    </form>
  </div>
</div>

<!-- قائمة الواجبات -->
<div class="row g-3">
  <% assignments.forEach(a => { %>
    <div class="col-md-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <span class="badge" style="background:#EEF0FB;color:#4338CA;">واجب رقم <%= a.order_number %></span>
            <form action="/hw/assignments/<%= a.id %>/delete" method="POST" onsubmit="return confirm('حذف الواجب؟')">
              <button class="btn btn-sm btn-outline-danger">🗑️</button>
            </form>
          </div>
          <h6 class="mb-1"><%= a.title %></h6>
          <p class="small text-muted mb-2"><%= a.description || '' %></p>
          <p class="small text-muted mb-3">
            📅 <%= a.start_date %> → <%= a.end_date %><br>
            <% if (a.Subject) { %>📚 <%= a.Subject.name %><% } %>
          </p>
          <a href="/hw/assignments/<%= a.id %>" class="btn btn-outline-primary w-100 btn-sm">عرض التسليمات</a>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<%- include('partials/footer') %>