<%- include('partials/header') %>

<h3 class="mb-4">🎯 إدارة توزيع المتابعة</h3>

<!-- الأسيستانتس وإحصائياتهم -->
<div class="row g-3 mb-4">
  <% Object.values(assistantStats).forEach(stat => { %>
    <div class="col-md-4">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between mb-2">
            <strong><%= stat.user.name %></strong>
            <span class="badge" style="background:#EEF0FB;color:#4338CA;"><%= stat.count %> طالب</span>
          </div>
          <form action="/admin/follow-up-management/settings" method="POST" class="d-flex gap-1 mb-2">
            <input type="number" name="max_<%= stat.user.id %>" class="form-control form-control-sm"
              value="<%= settings['max_' + stat.user.id] || 50 %>" placeholder="الحد الأقصى">
            <button class="btn btn-sm btn-outline-primary">حفظ</button>
          </form>
          <div style="max-height:150px;overflow-y:auto;">
            <% stat.students.forEach(s => { %>
              <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
                <span style="font-size:0.78rem;"><%= s?.name %></span>
                <form action="/admin/follow-up-management/unassign/<%= s?.id %>" method="POST">
                  <button class="btn btn-sm" style="padding:1px 6px;background:#FEE2E2;font-size:0.65rem;">إلغاء</button>
                </form>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<!-- تعيين يدوي -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="mb-3">تعيين طالب يدوياً</h6>
    <form action="/admin/follow-up-management/assign" method="POST" class="row g-2">
      <div class="col-md-4">
        <select name="student_id" class="form-select form-select-sm" required>
          <option value="">-- اختر الطالب --</option>
          <% unassignedStudents.forEach(s => { %>
            <option value="<%= s.id %>"><%= s.name %> - <%= s.student_code %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <select name="assistant_id" class="form-select form-select-sm" required>
          <option value="">-- اختر الأسيستانت --</option>
          <% followUpEligible.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <button class="btn btn-primary btn-sm w-100">تعيين</button>
      </div>
    </form>
  </div>
</div>

<!-- توزيع تلقائي -->
<div class="card shadow-sm mb-4">
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <h6 class="mb-1">توزيع تلقائي (Round-Robin)</h6>
      <p class="small text-muted mb-0">سيوزع <%= unassignedStudents.length %> طالب غير مُعيَّن على الأسيستانتس المتاحين</p>
    </div>
    <form action="/admin/follow-up-management/auto-assign" method="POST">
      <button class="btn btn-success" onclick="return confirm('سيتم التوزيع التلقائي. متأكد؟')">⚡ توزيع تلقائي</button>
    </form>
  </div>
</div>

<!-- كل الطلاب -->
<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="mb-3">👥 كل الطلاب</h6>

    <form action="/admin/follow-up-management/bulk-assign" method="POST" id="bulkForm">
      <div class="d-flex gap-2 mb-3 align-items-center flex-wrap p-2 rounded" style="background:#EEF0FB;">
        <div class="form-check mb-0">
          <input type="checkbox" class="form-check-input" id="selectAll" onchange="toggleAll(this)">
          <label class="form-check-label small fw-bold" for="selectAll">تحديد الكل</label>
        </div>
        <select name="assistant_id" class="form-select form-select-sm" style="width:180px;">
          <option value="">-- اختر أسيستانت --</option>
          <% followUpEligible.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.name %></option>
          <% }) %>
        </select>
        <button type="submit" name="action" value="assign" class="btn btn-sm btn-primary">تعيين للمختارين</button>
        <button type="submit" name="action" value="unassign" class="btn btn-sm btn-outline-danger"
          onclick="return confirm('إلغاء تعيين كل المحددين؟')">إلغاء تعيين المختارين</button>
        <span class="small text-muted ms-auto" id="selectedCount">0 محدد</span>
      </div>

      <input type="text" id="studentBulkSearch" class="form-control form-control-sm mb-3" placeholder="🔍 بحث...">

      <div class="table-responsive" style="max-height:500px;overflow-y:auto;">
        <table class="table table-sm table-hover" id="bulkTable">
          <thead class="table-light" style="position:sticky;top:0;">
            <tr>
              <th style="width:40px;"></th>
              <th>الطالب</th>
              <th>المادة</th>
              <th>السنتر</th>
              <th>الأسيستانت الحالي</th>
            </tr>
          </thead>
          <tbody>
            <%
              const assignedMap = {};
              assignments.forEach(a => { assignedMap[a.StudentId] = a.Assistant; });
            %>
            <% allStudentsForBulk.forEach(s => { %>
              <tr data-search="<%= (s.name + ' ' + s.student_code + ' ' + (s.Subject?.name||'') + ' ' + (s.Center?.name||'')).toLowerCase() %>">
                <td>
                  <input type="checkbox" name="student_ids" value="<%= s.id %>"
                    class="form-check-input student-checkbox" onchange="updateCount()">
                </td>
                <td>
                  <span class="small fw-bold"><%= s.name %></span><br>
                  <span class="text-muted" style="font-size:0.68rem;"><%= s.student_code %></span>
                </td>
                <td><span class="small"><%= s.Subject?.name || '-' %></span></td>
                <td><span class="small"><%= s.Center?.name || '-' %></span></td>
                <td>
                  <% const currentAss = assignedMap[s.id]; %>
                  <% if (currentAss) { %>
                    <span class="badge" style="background:#EEF0FB;color:#4338CA;font-size:0.7rem;"><%= currentAss.name %></span>
                  <% } else { %>
                    <span class="badge bg-secondary" style="font-size:0.65rem;">غير محدد</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </form>
  </div>
</div>

<script>
function toggleAll(master) {
  document.querySelectorAll('.student-checkbox').forEach(cb => cb.checked = master.checked);
  updateCount();
}

function updateCount() {
  const count = document.querySelectorAll('.student-checkbox:checked').length;
  document.getElementById('selectedCount').textContent = count + ' محدد';
}

document.getElementById('studentBulkSearch').addEventListener('input', function() {
  const term = this.value.toLowerCase();
  document.querySelectorAll('#bulkTable tbody tr').forEach(row => {
    row.style.display = row.dataset.search.includes(term) ? '' : 'none';
  });
});
</script>

<%- include('partials/footer') %>