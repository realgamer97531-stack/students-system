<%- include('partials/header') %>

<h3 class="mb-4">🔐 التحكم في مشاهدات: <%= video.title %></h3>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="mb-3">الإعدادات العامة (تخص كل الطلاب)</h6>
    <form action="/admin/videos/<%= video.id %>/session-settings" method="POST" class="row g-2 align-items-end">
      <div class="col-md-3 form-check ms-2">
        <input type="checkbox" class="form-check-input" name="is_free_for_all" id="freeCheck"
          <%= video.Session.is_free_for_all ? 'checked' : '' %>>
        <label class="form-check-label" for="freeCheck">مفتوحة مجانًا للجميع</label>
      </div>
      <div class="col-md-3">
        <label class="form-label small">عدد المشاهدات (حضر بالسنتر)</label>
        <input type="number" name="views_if_attended" class="form-control" value="<%= video.Session.views_if_attended %>">
      </div>
      <div class="col-md-3">
        <label class="form-label small">عدد المشاهدات (دفع)</label>
        <input type="number" name="views_if_paid" class="form-control" value="<%= video.Session.views_if_paid %>">
      </div>
      <div class="col-md-3">
        <button type="submit" class="btn btn-primary w-100">حفظ</button>
      </div>
    </form>
  </div>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="mb-3">🏫 الحصص المسموح لها بمشاهدة هذا الفيديو</h6>

    <div class="d-flex flex-wrap gap-2 mb-3">
      <% if (videoSessions.length === 0) { %>
        <span class="text-muted small">لا توجد حصص مرتبطة (الفيديو مرئي للجميع!)</span>
      <% } %>
      <% videoSessions.forEach(vs => { %>
        <div class="d-flex align-items-center gap-1 p-2 rounded" style="background:#EEF0FB;font-size:0.8rem;">
          <span><strong><%= vs.Session?.Subject?.name %></strong> - <%= vs.Session?.Center?.name %> (حصة <%= vs.Session?.lesson_number %>)</span>
          <form action="/admin/videos/<%= video.id %>/remove-session/<%= vs.SessionId %>" method="POST">
            <button class="btn btn-sm" style="padding:1px 6px;background:#FEE2E2;color:#B91C1C;font-size:0.65rem;">✕</button>
          </form>
        </div>
      <% }) %>
    </div>

    <form action="/admin/videos/<%= video.id %>/add-session" method="POST" class="d-flex gap-2">
      <select name="session_id" class="form-select form-select-sm" style="max-width:350px;" required>
        <option value="">-- إضافة حصة جديدة --</option>
        <% allSessions.forEach(s => { %>
          <% const alreadyAdded = videoSessions.some(vs => vs.SessionId === s.id); %>
          <% if (!alreadyAdded) { %>
            <option value="<%= s.id %>"><%= s.Subject?.name %> - <%= s.Center?.name %> (حصة <%= s.lesson_number %> | سيريال <%= s.serial_number %>)</option>
          <% } %>
        <% }) %>
      </select>
      <button class="btn btn-sm btn-primary">+ إضافة</button>
    </form>
  </div>
</div>

<div class="card shadow-sm mb-3">
  <div class="card-body">
    <h6 class="mb-3">👤 وصول فردي لطلاب بعينهم (خارج المجموعات المسموح بها)</h6>

    <div class="mb-3">
      <input id="studentSearch" type="text" class="form-control" placeholder="🔍 بحث بالاسم أو الكود"> 
    </div>

    <% if (studentAccesses.length === 0) { %>
      <p class="text-muted small">لا يوجد طلاب بوصول فردي حتى الآن.</p>
    <% } else { %>
      <div class="table-responsive mb-3">
        <table class="table table-sm align-middle" id="studentsTable">
          <thead class="table-light">
            <tr>
              <th>الكود</th>
              <th>الاسم</th>
              <th>الفرقة / السنتر</th>
              <th>طريقة الوصول</th>
              <th>المتبقي</th>
              <th>تعديل</th>
              <th>إلغاء</th>
            </tr>
          </thead>
          <tbody>
            <% studentAccesses.forEach(sa => { %>
              <tr data-search="<%= (sa.Student?.name + ' ' + sa.Student?.student_code).toLowerCase() %>">
                <td><%= sa.Student?.student_code %></td>
                <td><%= sa.Student?.name %></td>
                <td class="small text-muted"><%= sa.Student?.Subject?.name %> - <%= sa.Student?.Center?.name %></td>
                <td><%= sa.method %></td>
                <td><%= Math.max(sa.max_views - sa.views_used, 0) %> من <%= sa.max_views %></td>
                <td>
                  <form action="/admin/videos/<%= video.id %>/grant/<%= sa.Student.id %>" method="POST" class="row g-1 align-items-center">
                    <div class="col-auto">
                      <select name="method" class="form-select form-select-sm">
                        <option value="attended" <%= sa.method === 'attended' ? 'selected' : '' %>>حضور</option>
                        <option value="paid" <%= sa.method === 'paid' ? 'selected' : '' %>>دفع</option>
                        <option value="admin_free" <%= sa.method === 'admin_free' ? 'selected' : '' %>>مجاني</option>
                        <option value="admin_paid" <%= sa.method === 'admin_paid' ? 'selected' : '' %>>مدفوع</option>
                      </select>
                    </div>
                    <div class="col-auto">
                      <input type="number" name="max_views" class="form-control form-control-sm" style="width:100px;" value="<%= sa.max_views %>" min="0">
                    </div>
                    <div class="col-auto">
                      <button class="btn btn-sm btn-outline-primary">حفظ</button>
                    </div>
                  </form>
                </td>
                <td>
                  <form action="/admin/videos/<%= video.id %>/remove-student-access/<%= sa.id %>" method="POST">
                    <button class="btn btn-sm btn-outline-danger">إلغاء</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <form action="/admin/videos/<%= video.id %>/add-student-access" method="POST" class="d-flex gap-2">
      <input type="text" name="student_code" class="form-control form-control-sm" style="max-width:200px;"
        placeholder="كود الطالب (STU-XXXXX)" required>
      <button class="btn btn-sm btn-success">+ إضافة طالب</button>
    </form>
  </div>
</div>

<script>
  document.getElementById('studentSearch').addEventListener('input', function () {
    const term = this.value.toLowerCase().trim();
    document.querySelectorAll('#studentsTable tbody tr').forEach(row => {
      row.style.display = row.dataset.search.includes(term) ? '' : 'none';
    });
  });
</script>

<%- include('partials/footer') %>