<%- include('partials/header') %>
<% if (student.is_blocked) { %>
  <div class="alert alert-danger d-flex align-items-center gap-2 mb-3">
    <span style="font-size:1.5rem;">⛔</span>
    <div>
      <strong>هذا الطالب محظور من النظام</strong> - وصل لـ 3 إنذارات
      <% if (userRole === 'admin') { %>
        <form action="/students/<%= student.id %>/unblock" method="POST" class="d-inline ms-3">
          <button class="btn btn-sm btn-success">فك الحظر</button>
        </form>
      <% } %>
    </div>
  </div>
<% } %>

<div class="card shadow-sm mb-3" style="border-right: 4px solid <%= warnings.length === 3 ? '#DC2626' : warnings.length === 2 ? '#F59E0B' : '#E2E4F3' %>;">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h6 class="mb-0">🚨 الإنذارات</h6>
      <span class="badge" style="background: <%= warnings.length === 3 ? '#FEE2E2; color:#B91C1C' : warnings.length === 2 ? '#FEF3C7; color:#92400E' : '#EEF0FB; color:#4338CA' %>;">
        <%= warnings.length %> / 3
      </span>
    </div>

    <% if (warnings.length === 0) { %>
      <p class="text-muted small mb-2">لا يوجد إنذارات</p>
    <% } %>

    <ul class="list-group list-group-flush mb-3">
      <% warnings.forEach((w, i) => { %>
        <li class="list-group-item d-flex justify-content-between align-items-center small px-0">
          <span>
            <span class="badge bg-warning text-dark me-2">إنذار <%= i + 1 %></span>
            <%= w.reason || 'بدون سبب محدد' %><br>
            <span class="text-muted" style="font-size:0.7rem;">
              بواسطة: <%= w.User ? w.User.name : '-' %> -
              <%= new Date(w.createdAt).toLocaleString('ar-EG') %>
            </span>
          </span>
          <% if (userRole === 'admin') { %>
            <form action="/students/<%= student.id %>/warning/remove/<%= w.id %>" method="POST"
              onsubmit="return confirm('متأكد من إلغاء هذا الإنذار؟')">
              <button class="btn btn-sm btn-outline-secondary">إلغاء</button>
            </form>
          <% } %>
        </li>
      <% }) %>
    </ul>

    <% if (warnings.length < 3 && userRole === 'admin') { %>
      <form action="/students/<%= student.id %>/warning/add" method="POST" class="d-flex gap-2">
        <input type="text" name="reason" class="form-control form-control-sm" placeholder="سبب الإنذار (اختياري)">
        <button class="btn btn-sm btn-warning text-white" style="white-space:nowrap;">إضافة إنذار</button>
      </form>
    <% } %>
  </div>
</div>

<div class="row g-4">
  <!-- بيانات الطالب وتعديلها -->
  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="mb-3">بيانات الطالب</h5>
        <form action="/students/<%= student.id %>/edit" method="POST">
          <div class="mb-2">
            <label class="form-label">الاسم</label>
            <input type="text" name="name" class="form-control" value="<%= student.name %>" required>
          </div>
          <div class="mb-2">
            <label class="form-label">تليفون الطالب</label>
            <input type="text" name="phone" class="form-control" value="<%= student.phone %>" required>
          </div>
          <div class="mb-2">
            <label class="form-label">تليفون ولي الأمر</label>
            <input type="text" name="parent_phone" class="form-control" value="<%= student.parent_phone %>" required>
          </div>
          <div class="mb-2">
            <label class="form-label">المادة</label>
            <select name="subject_id" class="form-select" required>
              <% subjects.forEach(subj => { %>
                <option value="<%= subj.id %>" <%= subj.id === student.SubjectId ? 'selected' : '' %>>
                  <%= subj.name %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="mb-2">
            <label class="form-label">السنتر</label>
            <select name="center_id" class="form-select" required>
              <% centers.forEach(center => { %>
                <option value="<%= center.id %>" <%= center.id === student.CenterId ? 'selected' : '' %>>
                  <%= center.name %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="mb-2">
            <label class="form-label">سعر الحصة</label>
            <input type="number" name="price_per_session" class="form-control" value="<%= student.price_per_session %>" required>
          </div>
          <div class="mb-2 form-check">
            <input type="checkbox" name="booklet_status" class="form-check-input" <%= student.booklet_status ? 'checked' : '' %>>
            <label class="form-check-label">اشترى البوكليت</label>
          </div>
          <div class="mb-2">
  <label class="form-label">ملاحظة دائمة (تظهر للأسيستانت وقت تسجيل الحضور)</label>
  <textarea name="admin_note" class="form-control" rows="2"><%= student.admin_note || '' %></textarea>
</div>
          <button type="submit" class="btn btn-primary w-100 mt-2">حفظ التعديلات</button>
        </form>
      </div>
    </div>

    <!-- تعديل الرصيد -->
    <div class="card shadow-sm mt-3">
      <div class="card-body">
        <h5 class="mb-3">الرصيد الحالي: <span class="text-success"><%= student.balance %> ج</span></h5>
        <form action="/students/<%= student.id %>/balance" method="POST">
          <div class="mb-2">
            <label class="form-label">المبلغ</label>
            <input type="number" name="amount" class="form-control" placeholder="مثال: 320" required>
          </div>
          <div class="mb-2">
            <label class="form-label">نوع العملية</label>
            <select name="type" class="form-select">
              <option value="add">إضافة رصيد</option>
              <option value="deduct">خصم رصيد</option>
            </select>
          </div>
          <div class="mb-2">
            <label class="form-label">السبب (اختياري)</label>
            <input type="text" name="reason" class="form-control" placeholder="مثال: تجديد شهري">
          </div>
          <button type="submit" class="btn btn-success w-100">تنفيذ</button>
        </form>
      </div>
    </div>
    <div class="card shadow-sm mt-3">
  <div class="card-body">
    <h6 class="mb-3">⭐ النقاط: <span class="text-warning"><%= student.points || 0 %> نقطة</span></h6>
    <p class="small text-muted mb-2">
      نظام النقاط: حضور +2 | واجب كامل +3 | درجة امتحان = نفس عدد النقاط | مشاهدة فيديو +1
    </p>
    <form action="/students/<%= student.id %>/points" method="POST" class="row g-2">
      <div class="col-md-3">
        <input type="number" name="amount" class="form-control form-control-sm" placeholder="عدد النقاط" required min="1">
      </div>
      <div class="col-md-3">
        <select name="type" class="form-select form-select-sm">
          <option value="add">إضافة نقاط</option>
          <option value="deduct">خصم نقاط</option>
        </select>
      </div>
      <div class="col-md-4">
        <input type="text" name="reason" class="form-control form-control-sm" placeholder="السبب (اختياري)">
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-sm btn-warning w-100">تنفيذ</button>
      </div>
    </form>
    <hr class="my-2">
    <p class="small text-muted mb-1">سجل النقاط (آخر 10):</p>
    <ul class="list-group list-group-flush">
      <% transactions.filter(t => t.reason && t.reason.startsWith('نقاط:')).slice(0, 10).forEach(t => { %>
        <li class="list-group-item d-flex justify-content-between small px-0">
          <span><%= t.reason.replace('نقاط: ', '') %></span>
          <span class="<%= t.amount >= 0 ? 'text-success' : 'text-danger' %>">
            <%= t.amount >= 0 ? '+' : '' %><%= t.amount %>
          </span>
        </li>
      <% }) %>
    </ul>
  </div>
</div>

<div class="card shadow-sm mt-3">
  <div class="card-body">
    <h6 class="mb-3">📚 البوكليتس</h6>
    <% if (availableBooklets.length === 0) { %>
      <p class="text-muted small">لا يوجد بوكليتس لهذه المادة</p>
    <% } %>
    <% availableBooklets.forEach(b => { %>
      <% const sb = studentBooklets.find(s => s.BookletId === b.id); %>
      <% const paid = sb ? sb.paid_amount : 0; %>
      <% const remaining = b.sell_price - paid; %>
      <div class="border rounded p-2 mb-2">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <strong class="small"><%= b.name %></strong>
          <div class="d-flex gap-1 align-items-center">
            <% if (sb && sb.is_delivered) { %>
              <span class="badge bg-success" style="font-size:0.65rem;">✓ استلم</span>
            <% } else if (sb) { %>
              <% if (userRole === 'admin') { %>
              <form action="/students/<%= student.id %>/booklet-deliver/<%= sb.id %>" method="POST" class="d-inline">
                <button class="btn btn-sm" style="font-size:0.65rem;padding:2px 8px;background:#D1FAE5;color:#047857;">تسليم ✓</button>
              </form>
              <% } %>
            <% } %>
          </div>
        </div>
        <div class="d-flex justify-content-between small text-muted mb-2">
          <span>السعر: <%= b.sell_price %> ج</span>
          <span>مدفوع: <span class="text-success"><%= paid %> ج</span></span>
          <span>متبقي: <span class="<%= remaining > 0 ? 'text-danger' : 'text-success' %>"><%= remaining %> ج</span></span>
        </div>
        <% if (remaining > 0 && userRole === 'admin') { %>
          <form action="/students/<%= student.id %>/booklet-payment" method="POST" class="d-flex gap-1">
            <input type="hidden" name="booklet_id" value="<%= b.id %>">
            <input type="number" name="paid_amount" class="form-control form-control-sm" placeholder="المبلغ المدفوع" min="1" max="<%= remaining %>" required>
            <input type="text" name="notes" class="form-control form-control-sm" placeholder="ملاحظة">
            <button class="btn btn-sm btn-primary" style="white-space:nowrap;">دفع</button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>

    <!-- سجل تعديلات الرصيد -->
    <div class="card shadow-sm mt-3">
      <div class="card-body">
        <h6 class="mb-3">سجل تعديلات الرصيد</h6>
        <% if (transactions.length === 0) { %>
          <p class="text-muted small">لا يوجد تعديلات سابقة</p>
        <% } %>
        <ul class="list-group list-group-flush">
          <% transactions.forEach(t => { %>
            <li class="list-group-item d-flex justify-content-between small">
              <div>
                <span><%= t.reason || '-' %></span><br>
                <span class="text-muted" style="font-size: 0.65rem;">
                  <%= new Date(t.createdAt).toLocaleString('ar-EG') %>
                </span>
              </div>
              <span class="<%= t.amount >= 0 ? 'text-success' : 'text-danger' %>">
                <%= t.amount >= 0 ? '+' : '' %><%= t.amount %> ج
              </span>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
    <div class="card shadow-sm mt-3">
      <div class="card-body">
        <h6 class="mb-3">درجات الامتحانات</h6>
        <% if (examResults.length === 0) { %>
          <p class="text-muted small">لا يوجد امتحانات مرصودة بعد</p>
        <% } %>
        <ul class="list-group list-group-flush">
<% examResults.forEach(r => { %>
        <li class="list-group-item d-flex justify-content-between align-items-center small">
          <div>
            <span><%= r.Exam.name %></span><br>
            <span class="text-muted" style="font-size: 0.7rem;">
              رصده: <%= r.User ? r.User.name : '-' %><br>
              <%= new Date(r.createdAt).toLocaleString('ar-EG') %>
            </span>
          </div>
          <span><strong><%= r.score %></strong> / <%= r.Exam.max_score %></span>
        </li>
      <% }) %>
        </ul>
      </div>
    </div>
    <div class="card shadow-sm mt-3">
  <div class="card-body">
    <h6 class="mb-3">مشاهدات الفيديو</h6>
    <% if (videoWatchData.length === 0) { %>
      <p class="text-muted small">لا يوجد فيديوهات لمادة هذا الطالب</p>
    <% } %>
    <% videoWatchData.forEach(v => { %>
      <div class="mb-2 pb-2 border-bottom">
        <div class="d-flex justify-content-between">
          <strong class="small"><%= v.title %></strong>
          <span class="text-muted small">
            حصة <%= v.lessonNumber %><% if (v.centerName) { %> (<%= v.centerName %>)<% } %>
          </span>
        </div>
        <% v.parts.forEach(p => { %>
          <div class="d-flex justify-content-between small text-muted">
            <span><%= p.category %><% if (p.orderIndex > 1) { %> #<%= p.orderIndex %><% } %></span>
            <span>
              <%= Math.floor(p.watchedSeconds / 60) %>:<%= String(p.watchedSeconds % 60).padStart(2, '0') %>
              من
              <%= Math.floor(p.durationSeconds / 60) %>:<%= String(p.durationSeconds % 60).padStart(2, '0') %>
            </span>
          </div>
        <% }) %>
      </div>
    <% }) %>
  </div>
</div>
  </div>

  <!-- سجل الحضور والغياب -->
  <div class="col-md-7">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="mb-3">سجل الحضور والواجب (مادة <%= student.Subject.name %>)</h5>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
              <thead class="table-light">
                  <tr>
                    <th>رقم الحصة</th>
                    <th>السيريال بتاع مجموعته</th>
                    <th>التاريخ</th>
                    <th>الحضور</th>
                    <th>الواجب</th>
                    <th>الامتحان</th>
                  </tr>
                </thead>
              <tbody>
                <% attendanceRows.forEach(row => { %>
                  <tr>
                    <td><%= row.session.lesson_number %></td>
                    <td><%= row.session.serial_number %></td>
                    <td><%= row.session.session_date %></td>
                    <td>
                      <% if (row.attendanceStatus === 'attended') { %>
  <span class="badge bg-success">حضر</span><br>
  <span class="text-muted" style="font-size: 0.7rem;">
    سجّله: <%= row.attendanceUser %><br>
    <%= row.attendanceTime ? new Date(row.attendanceTime).toLocaleString('ar-EG') : '' %>
  </span>
  <% if (userRole === 'admin' && row.attendanceId) { %>
    <br>
    <form action="/attendance/<%= row.attendanceId %>/delete" method="POST" onsubmit="return confirm('متأكد من حذف سجل الحضور ده؟')">
      <button type="submit" class="btn btn-sm btn-outline-danger mt-1">حذف الحضور</button>
    </form>
  <% } %>
<% } else if (row.attendanceStatus === 'attended_elsewhere') { %>
  <span class="badge bg-info text-dark">حضر في: <%= row.attendedElsewhere %></span><br>
  <span class="text-muted" style="font-size: 0.7rem;">
    سجّله: <%= row.attendanceUser %><br>
    <%= row.attendanceTime ? new Date(row.attendanceTime).toLocaleString('ar-EG') : '' %>
  </span>
  <% if (userRole === 'admin' && row.attendanceId) { %>
    <br>
    <form action="/attendance/<%= row.attendanceId %>/delete" method="POST" onsubmit="return confirm('متأكد من حذف سجل الحضور ده؟ سيتم استرجاع المبلغ للطالب.')">
  <input type="hidden" name="redirect_to" value="/students/<%= student.id %>">
  <button type="submit" class="btn btn-sm btn-outline-danger mt-1">حذف الحضور</button>
</form>
  <% } %>
                        <% } else if (row.attendanceStatus === 'cancelled') { %>
                        <span class="badge bg-secondary">ملغية</span>
                      <% } else { %>
                        <span class="badge bg-danger">غاب</span>
                      <% } %>
                    </td>
                    <td>
                              <% if (!row.homeworkStatus) { %>
                                <span class="text-muted small">-</span>
                              <% } else { %>
                                <% if (row.homeworkStatus === 'complete') { %>
                                  <span class="badge bg-success">كامل</span>
                                <% } else if (row.homeworkStatus === 'incomplete') { %>
                                  <span class="badge bg-warning text-dark">مش كامل</span>
                                <% } else if (row.homeworkStatus === 'no_steps') { %>
                                  <span class="badge bg-secondary">من غير خطوات</span>
                                <% } else { %>
                                  <span class="badge bg-danger">مش معمول</span>
                                <% } %>
                                <br>
            <span class="text-muted" style="font-size: 0.7rem;">
              صحّحه: <%= row.homeworkUser %><br>
              <%= row.homeworkTime ? new Date(row.homeworkTime).toLocaleString('ar-EG') : '' %>
            </span>
          <% } %>
        </td>
                    <td>
                      <% if (row.examInfo) { %>
            <strong><%= row.examInfo.score %></strong> / <%= row.examInfo.max_score %><br>
            <span class="text-muted" style="font-size: 0.7rem;">
              رصده: <%= row.examInfo.recordedBy %><br>
              <%= row.examInfo.recordedAt ? new Date(row.examInfo.recordedAt).toLocaleString('ar-EG') : '' %>
            </span>
                      <% } else { %>
                        <span class="text-muted small">-</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>