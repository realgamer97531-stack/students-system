<%- include('partials/header') %>
<%- include('partials/session-switcher') %>

<div class="card mx-auto" style="max-width: 500px;">
  <div class="card-body p-4 text-center">
    <h4 class="mb-3">تسجيل حضور</h4>
    <p class="text-muted">
      الحصة الشغالة: <strong><%= activeSession.Subject.name %></strong>
      -
      <strong><%= activeSession.Center.name %></strong>
      (سيريال <%= activeSession.serial_number %>)
    </p>

    <div id="connectionStatus" class="alert alert-success small py-2 mb-3">🟢 متصل بالسيرفر</div>
    <div id="pendingBox" class="alert alert-warning small py-2 mb-3" style="display:none;"></div>
    
    <button type="button" class="btn btn-sm btn-outline-success w-100 mb-3" data-bs-toggle="modal" data-bs-target="#newStudentModal">
      ➕ تسجيل طالب جديد
    </button>
    
    <div id="reader" style="width: 100%; border-radius: var(--sf-radius); overflow: hidden; border: 1px solid var(--sf-input-border);"></div>

    <hr style="border-color: var(--sf-input-border);">
    <p class="text-muted small mb-2">أو اكتب كود الطالب يدويًا لو الكاميرا متعلقة:</p>
    <div class="input-group mb-3">
      <input type="text" id="manualCode" class="form-control" placeholder="مثال: STU-00001">
      <button class="btn btn-primary" onclick="submitManual()">إرسال</button>
    </div>



    <div id="summaryBox" style="display:none;" class="text-start mt-3">
      <div class="alert alert-secondary small" id="adminNoteBox" style="display:none;"></div>
      <h6 id="summaryStudentName" class="mb-2 fw-bold"></h6>
      
      <table class="table table-sm">
        <thead>
          <tr>
            <th>الحصة</th>
            <th>الحضور</th>
            <th>المشاهدة</th>
          </tr>
        </thead>
        <tbody id="summaryTableBody"></tbody>
      </table>
      <div id="bookletPaymentsBox"></div>
      <div class="mt-3">
        <div class="mb-2 text-start">
          <label class="form-label small fw-bold">💵 مبلغ الحصة (اختياري)</label>
          <input type="number" id="paymentInput" class="form-control form-control-sm" placeholder="0">
        </div>
        <div class="mb-2 text-start">
          <label class="form-label small fw-bold">💬 كومنت (اختياري)</label>
          <input type="text" id="commentInput" class="form-control form-control-sm" placeholder="ملاحظة...">
        </div>
      </div>
      
      <button class="btn btn-success w-100 mt-2" onclick="confirmAttendance()">✅ تأكيد تسجيل الحضور</button>
      <button class="btn btn-outline-secondary w-100 mt-2" onclick="cancelSummary()">إلغاء</button>
    </div>

    <div id="resultBox" class="mt-3"></div>

    <% if (userRole === 'admin') { %>
      <hr style="border-color: var(--sf-input-border);">
      <button class="btn btn-sm btn-outline-danger w-100" onclick="openForceModal()">
        ⚠️ تسجيل حضور بالقوة (حتى مع نقص الرصيد)
      </button>

      <div class="modal fade" id="forceModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content card">
            <div class="modal-header border-bottom-0">
              <h5 class="modal-title">تأكيد الهوية</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-start">
              <p class="small text-danger">هذا سيسجل حضور الطالب حتى لو رصيده غير كافٍ، وسيصبح الرصيد بالسالب.</p>
              <input type="text" id="forceCode" class="form-control mb-2" placeholder="كود الطالب">
              <input type="password" id="forcePassword" class="form-control" placeholder="كلمة المرور للتأكيد">
            </div>
            <div class="modal-footer border-top-0">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">رجوع</button>
              <button type="button" class="btn btn-danger" onclick="submitForce()">تأكيد التنفيذ</button>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>

<script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
<script>
  const STORAGE_KEY = 'pending_attendance_scans';
  const resultBox = document.getElementById('resultBox');
  const connectionStatus = document.getElementById('connectionStatus');
  const pendingBox = document.getElementById('pendingBox');
  const canDeliverBooklets = <%= userRole === 'admin' ? 'true' : 'false' %>;
  let isProcessing = false;

  // ===== إدارة قائمة العمليات المعلّقة (المخزّنة محليًا) =====
  function getPending() {
    return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
  }
  function savePending(list) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
    updatePendingDisplay();
  }
  function addPending(item) {
    const list = getPending();
    list.push(item);
    savePending(list);
  }
  function updatePendingDisplay() {
    const list = getPending();
    if (list.length > 0) {
      pendingBox.style.display = 'block';
      pendingBox.innerHTML = `⏳ في انتظار الاتصال: ${list.length} عملية متراكمة هترسل تلقائيًا`;
    } else {
      pendingBox.style.display = 'none';
    }
  }

  // ===== إرسال عملية واحدة للسيرفر =====
  async function sendToServer(payload) {
    const response = await fetch('/attendance/scan', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!response.ok) throw new Error('server error');
    return await response.json();
  }

  // ===== محاولة إرسال كل العمليات المعلّقة =====
  async function trySyncPending() {
    const list = getPending();
    if (list.length === 0) return;

    const remaining = [];
    for (const item of list) {
      try {
        await sendToServer(item);
      } catch (err) {
        remaining.push(item);
      }
    }
    savePending(remaining);
  }

  setInterval(trySyncPending, 10000);
  window.addEventListener('online', trySyncPending);

  function refreshConnectionStatus() {
    if (navigator.onLine) {
      connectionStatus.className = 'alert alert-success small py-2 mb-3';
      connectionStatus.textContent = '🟢 متصل بالسيرفر';
    } else {
      connectionStatus.className = 'alert alert-danger small py-2 mb-3';
      connectionStatus.textContent = '🔴 لا يوجد اتصال - البيانات هتُخزن وتُرسل تلقائيًا لما النت يرجع';
    }
  }
  window.addEventListener('online', refreshConnectionStatus);
  window.addEventListener('offline', refreshConnectionStatus);
  refreshConnectionStatus();
  updatePendingDisplay();
  trySyncPending();

  // ===== المنطق الأساسي لمعالجة كود الطالب =====
  let pendingCode = null;

  function processCode(code) {
    if (isProcessing) return;
    isProcessing = true;
    pendingCode = code;

    resultBox.innerHTML = `<div class="alert alert-info">⏳ بيتم التحقق من: ${code}</div>`;

    fetch('/attendance/scan/lookup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ student_code: code }),
    })
      .then(res => res.json())
      .then(data => {
        isProcessing = false;
        if (!data.success) {
          resultBox.innerHTML = `<div class="alert alert-warning">⚠️ ${data.message}</div>`;
          return;
        }
        showSummary(data);
      })
      .catch(() => {
        isProcessing = false;
        resultBox.innerHTML = `<div class="alert alert-danger">❌ حصلت مشكلة في الاتصال</div>`;
      });
  }

  function showSummary(data) {
    document.getElementById('reader').style.display = 'none';
    document.getElementById('manualCode').closest('.input-group').style.display = 'none';

    resultBox.innerHTML = '';
    document.getElementById('summaryStudentName').textContent =
      `${data.student.name} (${data.student.code}) - الرصيد: ${data.student.balance} ج`;

    const noteBox = document.getElementById('adminNoteBox');
    if (data.student.adminNote) {
      noteBox.style.display = 'block';
      noteBox.innerHTML = `📌 ملاحظة: ${data.student.adminNote}`;
    } else {
      noteBox.style.display = 'none';
    }

    const tbody = document.getElementById('summaryTableBody');
    tbody.innerHTML = '';
    data.summary.forEach(row => {
      let attendHtml = row.attended
        ? `<span class="badge bg-success">حضر (${row.attendedWhere})</span>`
        : `<span class="badge bg-danger">غاب</span>`;

      let watchHtml = '-';
      if (row.parts.length > 0) {
        watchHtml = row.parts.map(p => {
          const w = Math.floor(p.watchedSeconds / 60);
          const d = Math.floor(p.durationSeconds / 60);
          return `${p.category}: ${w}/${d} د`;
        }).join('<br>');
      }

      tbody.innerHTML += `<tr><td>${row.lessonNumber}</td><td>${attendHtml}</td><td class="small">${watchHtml}</td></tr>`;
    });
    // عرض البوكليتس
    const bookletBox = document.getElementById('bookletPaymentsBox');
    if (bookletBox) {
      const bookletItems = data.bookletStatuses || data.pendingBooklets || [];
      if (bookletItems.length > 0) {
        let bookletHtml = '<div class="mb-3 text-start"><label class="form-label small fw-bold">📚 البوكليتس</label>';
        bookletItems.forEach(b => {
          const isComplete = b.isDelivered || b.remaining <= 0;
          const badgeText = b.isDelivered ? '✓ استلم' : (b.remaining <= 0 ? '✓ مدفوع بالكامل' : `متبقي: ${b.remaining} ج`);
          const badgeClass = b.isDelivered || b.remaining <= 0 ? 'bg-success' : 'bg-warning text-dark';
          bookletHtml += `
            <div class="border rounded p-2 mb-2 bg-white">
              <div class="d-flex justify-content-between align-items-center small mb-1">
                <span><strong>${b.name}</strong></span>
                <div class="d-flex align-items-center gap-1 flex-wrap justify-content-end">
                  ${b.reservationStatus ? `<span class="badge bg-secondary" style="font-size:0.65rem;">حجز: ${b.reservationStatus}</span>` : ''}
                  <span class="badge ${badgeClass}" style="font-size:0.65rem;">${badgeText}</span>
                </div>
              </div>
              ${b.studentBookletId && !b.isDelivered ? `
                <div class="mt-2">
                  <div class="form-check">
                    <input class="form-check-input booklet-delivery-checkbox" type="checkbox"
                      data-student-id="${data.student.id}" data-student-booklet-id="${b.studentBookletId}"
                      id="booklet-deliver-${b.studentBookletId}">
                    <label class="form-check-label small" for="booklet-deliver-${b.studentBookletId}">
                      <span class="booklet-delivery-state text-warning">تم تسليم البوكليت</span>
                    </label>
                  </div>
                </div>
              ` : ''}
              ${!isComplete ? `
                <div class="input-group input-group-sm mt-2">
                  <input type="number" class="form-control booklet-payment-input"
                    data-booklet-id="${b.id}" data-remaining="${b.remaining}"
                    placeholder="المبلغ المدفوع الآن" min="0" max="${b.remaining}"
                    oninput="calcBookletRemaining(this, ${b.remaining})">
                  <span class="input-group-text small" id="remaining_${b.id}">سيتبقى: ${b.remaining} ج</span>
                </div>
              ` : ''}
            </div>`;
        });
        bookletHtml += '</div>';
        bookletBox.innerHTML = bookletHtml;
      } else {
        bookletBox.innerHTML = '';
      }
    }

    document.getElementById('summaryBox').style.display = 'block';
  }

  document.addEventListener('change', async function (event) {
    if (!event.target.classList.contains('booklet-delivery-checkbox')) return;
    const checkbox = event.target;
    if (!checkbox.checked) return;

    try {
      const response = await fetch('/attendance/scan/booklet-deliver', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          studentId: checkbox.dataset.studentId,
          studentBookletId: checkbox.dataset.studentBookletId,
        }),
      });
      const data = await response.json();
      if (data.success) {
        const state = checkbox.closest('.form-check').querySelector('.booklet-delivery-state');
        if (state) {
          state.className = 'booklet-delivery-state text-success fw-bold';
          state.textContent = 'تم التسليم';
        }
        checkbox.disabled = true;
      }
    } catch (err) {
      console.error(err);
    }
  });

  function cancelSummary() {
    document.getElementById('summaryBox').style.display = 'none';
    showScannerUI();
    pendingCode = null;
  }

  function showScannerUI() {
    document.getElementById('reader').style.display = 'block';
    document.getElementById('manualCode').closest('.input-group').style.display = 'flex';
  }

  function confirmAttendance() {
    const comment = document.getElementById('commentInput').value.trim();
    const payment = document.getElementById('paymentInput').value.trim();
    const bookletPayments = [];
    document.querySelectorAll('.booklet-payment-input').forEach(input => {
      const amount = parseFloat(input.value) || 0;
      if (amount > 0) bookletPayments.push({ booklet_id: input.dataset.bookletId, amount });
    });

    fetch('/attendance/scan', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        student_code: pendingCode,
        comment,
        payment_collected: payment,
        booklet_payments: bookletPayments,
      }),
    })
      .then(res => res.json())
      .then(data => {
        document.getElementById('summaryBox').style.display = 'none';
        showScannerUI();
        if (data.success) {
          resultBox.innerHTML = `
            <div class="alert alert-success">
              ✅ ${data.message}<br>
              الطالب: <strong>${data.student_name}</strong><br>
              الرصيد المتبقي: <strong>${data.remaining_balance} ج</strong>
            </div>`;
        } else {
          resultBox.innerHTML = `<div class="alert alert-warning">⚠️ ${data.message}</div>`;
        }
        document.getElementById('commentInput').value = '';
        document.getElementById('paymentInput').value = '';
        pendingCode = null;
      });
  }

  function submitManual() {
    const code = document.getElementById('manualCode').value.trim();
    if (code) {
      processCode(code);
      document.getElementById('manualCode').value = '';
    }
  }

  document.getElementById('manualCode').addEventListener('keypress', function (e) {
    if (e.key === 'Enter') submitManual();
  });

  function onScanSuccess(decodedText) {
    processCode(decodedText);
  }

  function openForceModal() {
    const modal = new bootstrap.Modal(document.getElementById('forceModal'));
    modal.show();
  }

  function submitForce() {
    const student_code = document.getElementById('forceCode').value.trim();
    const password = document.getElementById('forcePassword').value;

    fetch('/attendance/scan/force', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ student_code, password }),
    })
      .then(res => res.json())
      .then(data => {
        resultBox.innerHTML = `<div class="alert ${data.success ? 'alert-success' : 'alert-danger'}">${data.message}</div>`;
        if (data.success) {
          bootstrap.Modal.getInstance(document.getElementById('forceModal')).hide();
          document.getElementById('forceCode').value = '';
          document.getElementById('forcePassword').value = '';
        }
      });
  }

  const html5QrCode = new Html5Qrcode("reader");
  html5QrCode.start(
    { facingMode: "environment" },
    { fps: 10, qrbox: 250 },
    onScanSuccess
  ).catch(() => {
    // Fail-safe handling for cameras
  });
</script>

<div class="modal fade" id="newStudentModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content card">
      <div class="modal-header border-bottom-0">
        <h5 class="modal-title">تسجيل طالب جديد</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="quickAddForm">
        <div class="modal-body">
          <div id="quickAddError"></div>
          <div class="mb-2"><input type="text" name="name" class="form-control" placeholder="اسم الطالب" required></div>
          <div class="mb-2"><input type="text" name="phone" class="form-control" placeholder="تليفون الطالب" required></div>
          <div class="mb-2"><input type="text" name="parent_phone" class="form-control" placeholder="تليفون ولي الأمر" required></div>
          <div class="mb-2">
            <select name="subject_id" id="quickSubjectSelect" class="form-select" required>
              <option value="">-- المادة --</option>
              <% allSubjects.forEach(s => { %><option value="<%= s.id %>" data-price="<%= s.default_price %>"><%= s.name %></option><% }) %>
            </select>
          </div>
          <div class="mb-2">
            <select name="center_id" class="form-select" required>
              <option value="">-- السنتر --</option>
              <% allCenters.forEach(c => { %><option value="<%= c.id %>"><%= c.name %></option><% }) %>
            </select>
          </div>
          <div class="mb-2">
            <input type="number" name="price_per_session" id="quickPriceInput" class="form-control" placeholder="سعر الحصة" required>
          </div>
        </div>
        <div class="modal-footer border-top-0">
          <button type="submit" class="btn btn-success w-100">حفظ وعرض الكود</button>
        </div>
      </form>
      <div id="quickAddResult" class="p-3" style="display:none;"></div>
    </div>
  </div>
</div>

<script>
  document.getElementById('quickSubjectSelect').addEventListener('change', function () {
    const price = this.options[this.selectedIndex].dataset.price;
    if (price) document.getElementById('quickPriceInput').value = price;
  });

  document.getElementById('quickAddForm').addEventListener('submit', async function (e) {
    e.preventDefault();
    const formData = new FormData(this);
    const payload = Object.fromEntries(formData.entries());

    const res = await fetch('/students/quick-add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const data = await res.json();

    if (!data.success) {
      document.getElementById('quickAddError').innerHTML = `<div class="alert alert-danger small">${data.message}</div>`;
      return;
    }

    this.style.display = 'none';
    document.getElementById('quickAddResult').style.display = 'block';
    document.getElementById('quickAddResult').innerHTML = `
      <div class="text-center">
        <h6 class="fw-bold text-success">✅ تم التسجيل: ${data.student.name}</h6>
        <p class="mb-2">الكود: <strong>${data.student.student_code}</strong></p>
        <div class="p-2 d-inline-block bg-white rounded"><img src="${data.qrCodeImage}" style="max-width:150px;"></div>
      </div>`;
  });

  function calcBookletRemaining(input, totalRemaining) {
    const paid = parseFloat(input.value) || 0;
    const remaining = totalRemaining - paid;
    const bookletId = input.dataset.bookletId;
    const display = document.getElementById('remaining_' + bookletId);
    if (display) {
      display.textContent = `سيتبقى: ${Math.max(0, remaining).toFixed(1)} ج`;
      display.style.color = remaining <= 0 ? '#059669' : '#DC2626';
    }
  }
</script>
<%- include('partials/footer') %>