<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Studyisfunny | نظام المتابعة</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    :root {
      --sf-primary: #4338CA;
      --sf-primary-dark: #312E81;
      --sf-accent: #14B8A6;
      --sf-bg: #F5F6FB;
      --sf-sidebar: #1E1B4B;
      --sf-sidebar-hover: #312E81;
      --sf-text: #1E1B2E;
      --sf-muted: #6B7280;
      --sf-radius: 14px;
      --sf-shadow: 0 4px 14px rgba(30, 27, 75, 0.07);
      --sf-card-bg: #FFFFFF;
      --sf-input-border: #E2E4F3;
      --sf-table-header-bg: #EEF0FB;
    }

    /* Dark Mode Variables */
    [data-theme="dark"] {
      --sf-primary: #6366F1;
      --sf-primary-dark: #4F46E5;
      --sf-accent: #14B8A6;
      --sf-bg: #0F172A;
      --sf-sidebar: #1E293B;
      --sf-sidebar-hover: #334155;
      --sf-text: #E2E8F0;
      --sf-muted: #94A3B8;
      --sf-shadow: 0 4px 14px rgba(0, 0, 0, 0.5);
      --sf-card-bg: #1E293B;
      --sf-input-border: #334155;
      --sf-table-header-bg: #111827; /* Cleaned up to contrast beautifully with the cards */
    }

    * { font-family: 'Cairo', sans-serif; }

    body {
      display: flex;
      min-height: 100vh;
      margin: 0;
      background: var(--sf-bg);
      color: var(--sf-text);
    }

    .sidebar {
      width: 250px;
      background: linear-gradient(180deg, var(--sf-sidebar) 0%, #15132E 100%);
      color: #fff;
      padding: 22px 0;
      flex-shrink: 0;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      z-index: 1040;
      transition: transform 0.3s ease;
    }

    .sf-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-bottom: 6px;
    }
    .sf-logo-mark {
      width: 34px; height: 34px;
      background: linear-gradient(135deg, var(--sf-accent), var(--sf-primary));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; color: #fff; font-size: 1.1rem;
    }
    .sf-logo-text { font-weight: 800; font-size: 1.15rem; color: #fff; }
    .sf-logo-text span { color: var(--sf-accent); }

    .sidebar p.welcome {
      text-align: center; font-size: 0.78rem; color: #A5B4FC; margin-bottom: 22px;
    }

    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #C7C9E8;
      padding: 11px 22px;
      text-decoration: none;
      font-size: 0.92rem;
      font-weight: 500;
      transition: 0.2s;
      border-right: 3px solid transparent;
    }
    .sidebar a:hover {
      background: rgba(255,255,255,0.06);
      color: #fff;
      border-right-color: var(--sf-accent);
    }
    .sidebar hr { border-color: rgba(255,255,255,0.1); margin: 12px 22px; }

    .main-content { flex-grow: 1; padding: 28px; min-width: 0; }

    .container, .container-fluid { 
      background: var(--sf-bg);
    }

    h3, h4, h5, h6 { font-weight: 700; color: var(--sf-text); }
    h1, h2 { color: var(--sf-text); }

    .card {
      border: none;
      border-radius: var(--sf-radius);
      box-shadow: var(--sf-shadow);
      background: var(--sf-card-bg);
      color: var(--sf-text);
    }

    .btn {
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.88rem;
      padding: 0.5rem 1.1rem;
    }
    .btn-primary {
      background: var(--sf-primary);
      border-color: var(--sf-primary);
    }
    .btn-primary:hover { background: var(--sf-primary-dark); border-color: var(--sf-primary-dark); }
    .btn-success { background: var(--sf-accent); border-color: var(--sf-accent); }
    .btn-success:hover { background: #0F9488; border-color: #0F9488; }

    /* GLOBAL SYSTEM-WIDE ADAPTIVE TABLE FIX */
    .table { 
      border-radius: var(--sf-radius); 
      overflow: hidden;
      border: 1px solid var(--sf-input-border) !important;
      background: var(--sf-card-bg) !important;
      color: var(--sf-text) !important;
    }
    .table thead th {
      background: var(--sf-table-header-bg) !important;
      color: var(--sf-text) !important;
      font-weight: 700;
      font-size: 0.85rem;
      border: 1px solid var(--sf-input-border) !important;
    }
    .table tbody tr {
      background: var(--sf-card-bg) !important;
      border-bottom: 1px solid var(--sf-input-border) !important;
      transition: background 0.2s;
    }
    .table tbody tr:hover {
      background: var(--sf-table-header-bg) !important;
    }
    .table td { 
      font-size: 0.88rem; 
      vertical-align: middle; 
      color: var(--sf-text) !important;
      border: 1px solid var(--sf-input-border) !important;
      background: transparent !important;
    }
    
    /* Global subtle dimming for columns that hold auxiliary data */
    .table td:nth-child(1),
    .table td:not(:nth-child(2)) {
      color: var(--sf-muted) !important;
    }

    /* System link behavior handling color dynamics */
    .table td a {
      color: var(--sf-primary) !important;
      font-weight: 600;
    }
    [data-theme="dark"] .table td a {
      color: #60a5fa !important;
    }

    /* Clean translucent badges across all pages */
    .badge.bg-success {
      background-color: rgba(20, 184, 166, 0.15) !important;
      color: var(--sf-accent) !important;
      border: 1px solid rgba(20, 184, 166, 0.3);
    }
    .badge.bg-secondary {
      background-color: var(--sf-input-border) !important;
      color: var(--sf-muted) !important;
    }

    .badge { font-weight: 600; padding: 0.4em 0.7em; border-radius: 8px; }

    a { text-decoration: none; }
    a:hover { text-decoration: none; opacity: 0.8; }

    .form-control, .form-select {
      border-radius: 10px;
      border: 1px solid var(--sf-input-border);
      font-size: 0.9rem;
      background: var(--sf-card-bg);
      color: var(--sf-text);
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--sf-primary);
      box-shadow: 0 0 0 3px rgba(67, 56, 202, 0.12);
      background: var(--sf-card-bg);
      color: var(--sf-text);
    }

    .mobile-topbar { display: none; }
    .sidebar-overlay { display: none; }

    /* Fix text colors inside inputs and select options for Dark Mode */
.form-control, 
.form-select {
    color: #e2e8f0 !important;
    background-color: #1a202c !important;
    border-color: #4a5568 !important;
}

/* Fix contrast for input placeholders globally */
.form-control::placeholder {
    color: #a0aec0 !important;
    opacity: 1; /* Ensures browser defaults don't override it */
}

/* Fix faded/muted description text inside dark elements */
.text-muted, 
p.text-muted, 
span.text-muted {
    color: #cbd5e1 !important;
}

/* Specific fix for text inside option drops or disabled fields */
select option {
    background-color: #1a202c !important;
    color: #e2e8f0 !important;
}

    /* Language toggle classes */
    .ar-only { display: inline; }
    .en-only { display: none; }

    [lang="en"] .ar-only { display: none !important; }
    [lang="en"] .en-only { display: inline !important; }

    @media (max-width: 768px) {
      body { flex-direction: column; }
      .mobile-topbar {
        display: flex; align-items: center; justify-content: space-between;
        background: var(--sf-sidebar); color: #fff; padding: 14px 18px;
        position: sticky; top: 0; z-index: 1050;
      }
      .mobile-topbar button { background: none; border: none; color: #fff; font-size: 1.5rem; }
      .sidebar { position: fixed; right: 0; top: 0; height: 100vh; transform: translateX(100%); }
      .sidebar.open { transform: translateX(0); }
      .sidebar-overlay.show {
        display: block; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1035;
      }
      .main-content { padding: 16px; }
      table { font-size: 0.8rem; }
    }
  </style>

  <script>
    // Initialize theme on page load
    function initializeTheme() {
      const theme = localStorage.getItem('theme') || 'light';
      const lang = localStorage.getItem('language') || 'ar';
      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.setAttribute('lang', lang);
      document.documentElement.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
    }

    // Apply language display (show/hide text)
    function applyLanguageDisplay() {
      const lang = localStorage.getItem('language') || 'ar';
      const arElements = document.querySelectorAll('.ar-only');
      const enElements = document.querySelectorAll('.en-only');

      if (lang === 'ar') {
        arElements.forEach(el => el.style.display = '');
        enElements.forEach(el => el.style.display = 'none');
      } else {
        arElements.forEach(el => el.style.display = 'none');
        enElements.forEach(el => el.style.display = '');
      }
    }

    // Toggle theme between light and dark
    function toggleTheme() {
      const current = localStorage.getItem('theme') || 'light';
      const newTheme = current === 'light' ? 'dark' : 'light';
      localStorage.setItem('theme', newTheme);
      document.documentElement.setAttribute('data-theme', newTheme);
    }

    // Toggle language between Arabic and English
    function toggleLanguage() {
      const current = localStorage.getItem('language') || 'ar';
      const newLang = current === 'ar' ? 'en' : 'ar';
      localStorage.setItem('language', newLang);
      window.location.reload();
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', function() {
      initializeTheme();
      applyLanguageDisplay();
    });
  </script>
</head>
<body onload="initializeTheme(); applyLanguageDisplay();">
