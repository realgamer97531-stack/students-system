<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Studyisfunny | نظام المتابعة</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    :root {
      --sf-primary: #4338CA;
      --sf-primary-dark: #312E81;
      --sf-accent: #14B8A6;
      --sf-bg: #F5F6FB;
      --sf-sidebar: #1E1B4B;
      --sf-sidebar-hover: #312E81;
      --sf-text: #1E1B2E;
      --sf-muted: #6B7280;
      --sf-radius: 14px;
      --sf-shadow: 0 4px 14px rgba(30, 27, 75, 0.07);
    }

    * { font-family: 'Cairo', sans-serif; }

    body {
      display: flex;
      min-height: 100vh;
      margin: 0;
      background: var(--sf-bg);
      color: var(--sf-text);
    }

    .sidebar {
      width: 250px;
      background: linear-gradient(180deg, var(--sf-sidebar) 0%, #15132E 100%);
      color: #fff;
      padding: 22px 0;
      flex-shrink: 0;
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      z-index: 1040;
      transition: transform 0.3s ease;
    }

    .sf-logo {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-bottom: 6px;
    }
    .sf-logo-mark {
      width: 34px; height: 34px;
      background: linear-gradient(135deg, var(--sf-accent), var(--sf-primary));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; color: #fff; font-size: 1.1rem;
    }
    .sf-logo-text { font-weight: 800; font-size: 1.15rem; color: #fff; }
    .sf-logo-text span { color: var(--sf-accent); }

    .sidebar p.welcome {
      text-align: center; font-size: 0.78rem; color: #A5B4FC; margin-bottom: 22px;
    }

    .sidebar a {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #C7C9E8;
      padding: 11px 22px;
      text-decoration: none;
      font-size: 0.92rem;
      font-weight: 500;
      transition: 0.2s;
      border-right: 3px solid transparent;
    }
    .sidebar a:hover {
      background: rgba(255,255,255,0.06);
      color: #fff;
      border-right-color: var(--sf-accent);
    }
    .sidebar hr { border-color: rgba(255,255,255,0.1); margin: 12px 22px; }

    .main-content { flex-grow: 1; padding: 28px; min-width: 0; }

    h3, h4, h5, h6 { font-weight: 700; color: var(--sf-text); }

    .card {
      border: none;
      border-radius: var(--sf-radius);
      box-shadow: var(--sf-shadow);
    }

    .btn {
      border-radius: 10px;
      font-weight: 600;
      font-size: 0.88rem;
      padding: 0.5rem 1.1rem;
    }
    .btn-primary {
      background: var(--sf-primary);
      border-color: var(--sf-primary);
    }
    .btn-primary:hover { background: var(--sf-primary-dark); border-color: var(--sf-primary-dark); }
    .btn-success { background: var(--sf-accent); border-color: var(--sf-accent); }
    .btn-success:hover { background: #0F9488; border-color: #0F9488; }

    .table { border-radius: var(--sf-radius); overflow: hidden; }
    .table thead th {
      background: #EEF0FB;
      color: var(--sf-primary-dark);
      font-weight: 700;
      font-size: 0.85rem;
      border: none;
    }
    .table td { font-size: 0.88rem; vertical-align: middle; }

    .badge { font-weight: 600; padding: 0.4em 0.7em; border-radius: 8px; }

    a { text-decoration: none; }
    a:hover { text-decoration: none; opacity: 0.8; }

    .form-control, .form-select {
      border-radius: 10px;
      border: 1px solid #E2E4F3;
      font-size: 0.9rem;
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--sf-primary);
      box-shadow: 0 0 0 3px rgba(67, 56, 202, 0.12);
    }

    .mobile-topbar { display: none; }
    .sidebar-overlay { display: none; }

    @media (max-width: 768px) {
      body { flex-direction: column; }
      .mobile-topbar {
        display: flex; align-items: center; justify-content: space-between;
        background: var(--sf-sidebar); color: #fff; padding: 14px 18px;
        position: sticky; top: 0; z-index: 1050;
      }
      .mobile-topbar button { background: none; border: none; color: #fff; font-size: 1.5rem; }
      .sidebar { position: fixed; right: 0; top: 0; height: 100vh; transform: translateX(100%); }
      .sidebar.open { transform: translateX(0); }
      .sidebar-overlay.show {
        display: block; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 1035;
      }
      .main-content { padding: 16px; }
      table { font-size: 0.8rem; }
    }
  </style>
</head>
<body>

  <div class="mobile-topbar">
    <strong>Study<span style="color:#14B8A6">is</span>funny</strong>
    <button onclick="toggleSidebar()">☰</button>
  </div>

  <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

  <div class="sidebar" id="sidebar">
    <div class="sf-logo">
      <div class="sf-logo-mark">S</div>
      <div class="sf-logo-text">Study<span>is</span>funny</div>
    </div>
    <p class="welcome">مرحبًا، <%= userName %> (<%= userRole === 'admin' ? 'أدمن' : 'أسيستانت' %>)</p>

    <% function canShow(key) { return userRole === 'admin' || userPermissions.includes(key); } %>

    <% if (canShow('students_view')) { %><a href="/students">📋 قائمة الطلاب</a><% } %>
    <% if (canShow('students_add')) { %><a href="/students/new">➕ تسجيل طالب جديد</a><% } %>
    <hr>
    <% if (canShow('sessions_view')) { %><a href="/sessions">🗂️ كل الحصص</a><% } %>
    <% if (canShow('sessions_view')) { %><a href="/schedule">📅 الجدول الأسبوعي</a><% } %>
    <% if (canShow('students_view')) { %><a href="/follow-up">⚠️ يحتاجون متابعة</a><% } %>
    <% if (canShow('sessions_create')) { %><a href="/sessions/new">▶️ بدء حصة جديدة</a><% } %>
    <hr>
    <% if (canShow('attendance_scan')) { %><a href="/attendance/scan">✅ تسجيل حضور</a><% } %>
    <% if (canShow('homework_scan')) { %><a href="/homework/scan">📝 تصحيح الواجب</a><% } %>
    <% if (canShow('homework_scan')) { %><a href="/hw/assignments">📋 الواجبات أونلاين</a><% } %>
    <% if (canShow('door_scan')) { %><a href="/door/scan">🚪 سكان الباب</a><% } %>
    <hr>
    <% if (canShow('exams')) { %><a href="/exams">📊 الامتحانات والدرجات</a><% } %>
    <% if (canShow('admin_videos')) { %><hr><a href="/admin/videos">🎬 إدارة الفيديوهات</a><% } %>
    <% if (userRole === 'admin') { %>
      <hr>
      <a href="/users">👤 إدارة المستخدمين</a>
      <a href="/admin/closing">💰 التقفيل</a>
      <a href="/analytics" onclick="fetch('/analytics/lock')">📊 الداشبورد التحليلي</a>
      <a href="/admin/recharge-codes">🎫 أكواد الشحن</a>
      <a href="/admin/payment-verifications">🎫 التحقق من المدفوعات</a>
    <% } %>
    <hr>
    <a href="/logout">🚪 تسجيل خروج</a>
  </div>

  <div class="main-content">