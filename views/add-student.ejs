<%- include('partials/header') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          <h3 class="text-primary mb-3">➕ تسجيل طالب جديد</h3>
          <p class="text-muted mb-4">أدخل بيانات الطالب وسيتم حفظها في النظام.</p>

          <form action="/students" method="POST">
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">اسم الطالب</label>
                <input type="text" name="name" class="form-control" required>
              </div>

              <div class="col-md-6">
                <label class="form-label fw-semibold">تليفون الطالب</label>
                <input type="text" name="phone" class="form-control" required>
              </div>

              <div class="col-md-6">
                <label class="form-label fw-semibold">تليفون ولي الأمر</label>
                <input type="text" name="parent_phone" class="form-control" required>
              </div>

              <div class="col-md-6">
                <label class="form-label fw-semibold">سعر الحصة (ج)</label>
                <input type="number" name="price_per_session" class="form-control" min="0" step="0.01" required>
              </div>

              <div class="col-md-6">
                <label class="form-label fw-semibold">الرصيد الابتدائي</label>
                <input type="number" name="balance" class="form-control" min="0" step="0.01" value="0">
              </div>

              <div class="col-md-6">
                <label class="form-label fw-semibold">المادة</label>
                <select name="subject_id" class="form-select" required>
                  <% (subjects || []).forEach(subj => { %>
                    <option value="<%= subj.id %>"><%= subj.name %></option>
                  <% }) %>
                </select>
              </div>

              <div class="col-md-6">
                <label class="form-label fw-semibold">السنتر</label>
                <select name="center_id" class="form-select" required>
                  <% (centers || []).forEach(center => { %>
                    <option value="<%= center.id %>"><%= center.name %></option>
                  <% }) %>
                </select>
              </div>

              <div class="col-md-6">
                <label class="form-label fw-semibold">مبلغ بوكليت مدفوع</label>
                <input type="number" name="booklet_paid_amount" class="form-control" min="0" step="0.01" value="0">
              </div>
            </div>

            <div class="row g-3 mt-1">
              <div class="col-md-6">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" name="booklet_status" value="on" id="bookletStatus">
                  <label class="form-check-label fw-semibold" for="bookletStatus">يوجد بوكليت</label>
                </div>
              </div>

              <div class="col-md-6">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" name="register_attendance" value="on" id="registerAttendance">
                  <label class="form-check-label fw-semibold" for="registerAttendance">تسجيل حضور في الحصة الحالية</label>
                </div>
              </div>
            </div>

            <div class="mt-4">
              <button type="submit" class="btn btn-primary fw-bold px-4">💾 حفظ الطالب</button>
              <a href="/students" class="btn btn-outline-secondary ms-2">إلغاء</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>