<%- include('partials/header') %>

  <div class="container py-5">
    <div class="card shadow-lg mx-auto border-0" style="max-width: 650px; border-radius: 15px; overflow: hidden;">
      
      <!-- هيدر الصفحة الملون -->
      <div class="bg-primary text-white p-4 text-center">
        <h3 class="mb-1 fw-bold">✨ تسجيل طالب جديد</h3>
        <p class="mb-0 text-white-50 small">أدخل بيانات الطالب لإضافته للنظام</p>
      </div>

      <div class="card-body p-4 p-md-5 bg-white">

        <!-- رسالة التحذير من الازدواج -->
        <div id="duplicateAlert" class="alert alert-danger shadow-sm border-danger border-2 mb-4 rounded-3" style="display: none;">
          <div class="d-flex align-items-center gap-2 mb-3 border-bottom border-danger pb-2">
            <span style="font-size: 1.8rem;">🚨</span>
            <h5 class="fw-bold mb-0 text-danger">تحذير: طالب مكرر!</h5>
          </div>
          <p id="duplicateMessage" class="mb-3 fw-semibold"></p>
          <div class="mb-3 bg-white p-3 rounded border">
            <label class="form-label text-muted small fw-bold">🔑 كلمة المرور الإدارية لتجاوز التحذير</label>
            <input type="password" id="adminPassword" class="form-control" placeholder="أدخل كلمة المرور لتأكيد التسجيل">
          </div>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-danger fw-bold w-50" id="confirmDuplicateBtn">متابعة التسجيل</button>
            <button type="button" class="btn btn-light border w-50" id="cancelDuplicateBtn">إلغاء والتعديل</button>
          </div>
        </div>

        <form id="studentForm" action="/students" method="POST">
          
          <!-- القسم الأول: البيانات الأساسية -->
          <div class="bg-light p-4 rounded-3 border mb-4">
            <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">🧑‍🎓 البيانات الأساسية</h6>
            
            <div class="mb-3">
              <label class="form-label fw-semibold small text-secondary">اسم الطالب</label>
              <input type="text" name="name" class="form-control" placeholder="اكتب الاسم ثلاثي أو رباعي" required>
            </div>

            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-secondary">📱 رقم تليفون الطالب</label>
                <input type="text" name="phone" class="form-control" placeholder="01..." required>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-secondary">📞 رقم تليفون ولي الأمر</label>
                <input type="text" name="parent_phone" class="form-control" placeholder="01..." required>
              </div>
            </div>
          </div>

          <!-- القسم الثاني: تفاصيل الحجز -->
          <div class="bg-light p-4 rounded-3 border mb-4">
            <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">🏫 تفاصيل الحجز والمجموعة</h6>
            
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-secondary">المادة</label>
                <select name="subject_id" id="subjectSelect" class="form-select" required>
                  <option value="">-- اختر المادة --</option>
                  <% subjects.forEach(subj => { %>
                    <option value="<%= subj.id %>" data-price="<%= subj.default_price %>">
                      <%= subj.name %>
                    </option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-secondary">السنتر</label>
                <select name="center_id" class="form-select" required>
                  <option value="">-- اختر السنتر --</option>
                  <% centers.forEach(center => { %>
                    <option value="<%= center.id %>"><%= center.name %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="mb-2">
              <label class="form-label fw-semibold small text-secondary">💵 سعر الحصة (جنيه)</label>
              <input type="number" name="price_per_session" id="priceInput" class="form-control text-primary fw-bold" placeholder="يتحدد تلقائياً وقابل للتعديل" required>
              <div class="form-text text-muted" style="font-size: 0.75rem;">* يمكنك تعديل هذا السعر كحالة استثنائية لهذا الطالب.</div>
            </div>
          </div>

          <!-- القسم الثالث: البوكليت والرصيد -->
          <div class="bg-light p-4 rounded-3 border mb-4">
            <h6 class="text-primary fw-bold mb-3 border-bottom pb-2">📚 المصروفات والبوكليت</h6>
            
            <div class="row g-3 align-items-center mb-3">
              <div class="col-md-12">
                <div class="form-check form-switch bg-white p-2 rounded border d-flex align-items-center justify-content-between">
                  <label class="form-check-label fw-semibold mb-0 ms-2" for="bookletCheck">الطالب اشترى البوكليت؟</label>
                  <input type="checkbox" name="booklet_status" class="form-check-input m-0" id="bookletCheck" style="width: 2.5rem; height: 1.25rem;">
                </div>
              </div>
            </div>

            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-secondary">المبلغ المدفوع للبوكليت الآن</label>
                <div class="input-group">
                  <input type="number" name="booklet_paid_amount" class="form-control" min="0" step="0.01" value="0">
                  <span class="input-group-text bg-white">ج.م</span>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold small text-secondary">رصيد ابتدائي (اختياري)</label>
                <div class="input-group">
                  <input type="number" name="balance" class="form-control" value="0">
                  <span class="input-group-text bg-white">ج.م</span>
                </div>
              </div>
            </div>
          </div>

          <!-- القسم الرابع: حضور سريع -->
          <div class="p-3 mb-4 rounded-3 border" style="background-color: #f0fdf4; border-color: #bbf7d0 !important;">
            <div class="form-check form-switch d-flex align-items-center justify-content-between mb-1">
              <label class="form-check-label fw-bold text-success mb-0 ms-2" for="registerAttendanceCheck">🏃‍♂️ أضف هذا الطالب كحاضر في الحصة الحالية</label>
              <input type="checkbox" name="register_attendance" class="form-check-input m-0 bg-success border-success" id="registerAttendanceCheck" style="width: 2.5rem; height: 1.25rem;">
            </div>
            <div class="form-text text-success" style="font-size: 0.75rem;">* سيتم تسجيله فوراً في كشف حضور اليوم.</div>
          </div>

          <!-- زر الحفظ -->
          <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm" style="border-radius: 10px;">
            💾 حفظ بيانات الطالب
          </button>
        </form>
      </div>
    </div>
  </div>

  <script>
    const subjectSelect = document.getElementById('subjectSelect');
    const priceInput = document.getElementById('priceInput');
    const studentForm = document.getElementById('studentForm');
    const duplicateAlert = document.getElementById('duplicateAlert');
    const adminPasswordInput = document.getElementById('adminPassword');
    let hiddenAdminPassword = ''; // Variable to store admin password
    const confirmDuplicateBtn = document.getElementById('confirmDuplicateBtn');
    const cancelDuplicateBtn = document.getElementById('cancelDuplicateBtn');

    // تحديث السعر تلقائياً عند اختيار المادة
    subjectSelect.addEventListener('change', function () {
      const selectedOption = this.options[this.selectedIndex];
      const price = selectedOption.getAttribute('data-price');
      if (price) priceInput.value = price;
    });

    // إرسال النموذج مع التحقق من الازدواج
    studentForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formDataObj = {
        name: studentForm.querySelector('[name="name"]').value,
        phone: studentForm.querySelector('[name="phone"]').value,
        parent_phone: studentForm.querySelector('[name="parent_phone"]').value,
        subject_id: studentForm.querySelector('[name="subject_id"]').value,
        center_id: studentForm.querySelector('[name="center_id"]').value,
        price_per_session: studentForm.querySelector('[name="price_per_session"]').value,
        balance: studentForm.querySelector('[name="balance"]').value,
        booklet_status: studentForm.querySelector('[name="booklet_status"]').checked ? 'on' : '',
        booklet_paid_amount: studentForm.querySelector('[name="booklet_paid_amount"]').value,
        register_attendance: studentForm.querySelector('[name="register_attendance"]').checked ? 'on' : '',
        admin_password: hiddenAdminPassword,
      };

      try {
        const response = await fetch('/students', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formDataObj),
        });

        // إذا كان هناك تحذير ازدواج
        if (response.status === 409) {
          const data = await response.json();
          if (data.isDuplicate) {
            document.getElementById('duplicateMessage').textContent = data.message;
            duplicateAlert.style.display = 'block';
            studentForm.style.display = 'none';
            adminPasswordInput.focus();
            return;
          }
        }

        // إذا كان النجاح
        if (response.ok) {
          const html = await response.text();
          document.body.innerHTML = html;
        } else {
          const errorText = await response.text();
          alert('❌ حصلت مشكلة: ' + errorText);
        }
      } catch (error) {
        alert('❌ خطأ في الاتصال: ' + error.message);
      }
    });

    // تأكيد التسجيل مع كلمة المرور
    confirmDuplicateBtn.addEventListener('click', () => {
      const password = adminPasswordInput.value;
      if (!password) {
        alert('⚠️ الرجاء إدخال كلمة المرور الإدارية');
        return;
      }

      hiddenAdminPassword = password;
      studentForm.dispatchEvent(new Event('submit'));
    });

    // إلغاء والعودة للنموذج
    cancelDuplicateBtn.addEventListener('click', () => {
      duplicateAlert.style.display = 'none';
      studentForm.style.display = 'block';
      adminPasswordInput.value = '';
      hiddenAdminPassword = '';
    });
  </script>

<%- include('partials/footer') %>