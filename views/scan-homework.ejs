<%- include('partials/header') %>
<%- include('partials/session-switcher') %>

<div class="card mx-auto" style="max-width: 500px;">
  <div class="card-body p-4 text-center">
    <h4 class="mb-3">تصحيح الواجب</h4>
    <p class="text-muted">
      الحصة: <strong><%= activeSession.Subject.name %></strong> -
      <strong><%= activeSession.Center.name %></strong>
    </p>

    <div id="connectionStatus" class="alert alert-success small py-2 mb-3">🟢 متصل بالسيرفر</div>
    <div id="pendingBox" class="alert alert-warning small py-2 mb-3" style="display:none;"></div>

    <div id="reader" style="width: 100%; border-radius: var(--sf-radius); overflow: hidden; border: 1px solid var(--sf-input-border);"></div>

    <hr style="border-color: var(--sf-input-border);">
    <p class="text-muted small mb-2">أو اكتب كود الطالب يدويًا:</p>
    <div class="input-group mb-3">
      <input type="text" id="manualCode" class="form-control" placeholder="مثال: STU-00001">
      <button class="btn btn-primary" onclick="submitManual()">تأكيد الكود</button>
    </div>

    <div id="homeworkSummaryBox" style="display:none;" class="text-start mb-3">
      <div class="alert alert-secondary small" id="hwAdminNoteBox" style="display:none;"></div>
      <h6 id="hwStudentName" class="mb-2 fw-bold"></h6>
      <table class="table table-sm">
        <thead>
          <tr>
            <th>الحصة</th>
            <th>السنتر</th>
            <th>حالة الواجب</th>
          </tr>
        </thead>
        <tbody id="hwSummaryTableBody"></tbody>
      </table>
    </div>

    <div id="studentBox" class="mt-3" style="display:none;">
      <h6 class="mb-3">الكود المختار: <strong id="currentCode"></strong></h6>
      <div class="d-grid gap-2">
        <button class="btn btn-success" onclick="saveStatus('complete')">كامل</button>
        <button class="btn btn-warning" onclick="saveStatus('incomplete')">مش كامل</button>
        <button class="btn btn-secondary" onclick="saveStatus('no_steps')">من غير خطوات</button>
        <button class="btn btn-danger" onclick="saveStatus('not_done')">مش معمول</button>
        <button class="btn btn-outline-secondary btn-sm" onclick="cancelSelection()">إلغاء واختيار طالب تاني</button>
      </div>
    </div>

    <div id="resultBox" class="mt-3"></div>
  </div>
</div>

<script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
<script>
  const STORAGE_KEY = 'pending_homework_scans';
  const resultBox = document.getElementById('resultBox');
  const connectionStatus = document.getElementById('connectionStatus');
  const pendingBox = document.getElementById('pendingBox');
  const studentBox = document.getElementById('studentBox');
  const readerBox = document.getElementById('reader');
  const currentCode = document.getElementById('currentCode');

  let scanning = true;
  let selectedCode = null;

  function getPending() {
    return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
  }
  function savePending(list) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
    updatePendingDisplay();
  }
  function addPending(item) {
    const list = getPending();
    list.push(item);
    savePending(list);
  }
  function updatePendingDisplay() {
    const list = getPending();
    if (list.length > 0) {
      pendingBox.style.display = 'block';
      pendingBox.innerHTML = `⏳ في انتظار الاتصال: ${list.length} عملية متراكمة هترسل تلقائيًا`;
    } else {
      pendingBox.style.display = 'none';
    }
  }

  async function sendToServer(payload) {
    const response = await fetch('/homework/scan/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!response.ok) throw new Error('server error');
    return await response.json();
  }

  async function trySyncPending() {
    const list = getPending();
    if (list.length === 0) return;
    const remaining = [];
    for (const item of list) {
      try {
        await sendToServer(item);
      } catch (err) {
        remaining.push(item);
      }
    }
    savePending(remaining);
  }

  setInterval(trySyncPending, 10000);
  window.addEventListener('online', trySyncPending);

  function refreshConnectionStatus() {
    if (navigator.onLine) {
      connectionStatus.className = 'alert alert-success small py-2 mb-3';
      connectionStatus.textContent = '🟢 متصل بالسيرفر';
    } else {
      connectionStatus.className = 'alert alert-danger small py-2 mb-3';
      connectionStatus.textContent = '🔴 لا يوجد اتصال - البيانات هتُخزن وتُرسل تلقائيًا لما النت يرجع';
    }
  }
  window.addEventListener('online', refreshConnectionStatus);
  window.addEventListener('offline', refreshConnectionStatus);
  refreshConnectionStatus();
  updatePendingDisplay();
  trySyncPending();

  function selectCode(code) {
    if (!scanning) return;
    scanning = false;
    selectedCode = code;
    currentCode.textContent = code;
    studentBox.style.display = 'block';
    readerBox.style.display = 'none';
    resultBox.innerHTML = '';

    fetch('/homework/scan/summary', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ student_code: code }),
    })
      .then(res => res.json())
      .then(data => {
        if (!data.success) return;

        document.getElementById('hwStudentName').textContent = data.studentName;

        const noteBox = document.getElementById('hwAdminNoteBox');
        if (data.adminNote) {
          noteBox.style.display = 'block';
          noteBox.innerHTML = `📌 ملاحظة: ${data.adminNote}`;
        } else {
          noteBox.style.display = 'none';
        }

        const tbody = document.getElementById('hwSummaryTableBody');
        tbody.innerHTML = '';
        data.summary.forEach(row => {
          tbody.innerHTML += `<tr><td>${row.lessonNumber}</td><td>${row.centerName}</td><td>${row.homeworkStatus}</td></tr>`;
        });

        document.getElementById('homeworkSummaryBox').style.display = 'block';
      });
  }

  function cancelSelection() {
    selectedCode = null;
    studentBox.style.display = 'none';
    readerBox.style.display = 'block';
    document.getElementById('homeworkSummaryBox').style.display = 'none';
    scanning = true;
  }

  function submitManual() {
    const code = document.getElementById('manualCode').value.trim();
    if (code) {
      selectCode(code);
      document.getElementById('manualCode').value = '';
    }
  }

  document.getElementById('manualCode').addEventListener('keypress', function (e) {
    if (e.key === 'Enter') submitManual();
  });

  function saveStatus(status) {
    const payload = { student_code: selectedCode, status };

    sendToServer(payload)
      .then(data => {
        if (data.success) {
          resultBox.innerHTML = `<div class="alert alert-success">✅ ${data.message}${data.student_name ? ' - ' + data.student_name : ''}</div>`;
        } else {
          resultBox.innerHTML = `<div class="alert alert-warning">⚠️ ${data.message}</div>`;
        }
      })
      .catch(() => {
        addPending(payload);
        resultBox.innerHTML = `<div class="alert alert-warning">📴 لا يوجد اتصال - تم حفظ العملية محليًا وهتُرسل تلقائيًا لما النت يرجع.</div>`;
      })
      .finally(() => {
        studentBox.style.display = 'none';
        readerBox.style.display = 'block';
        document.getElementById('homeworkSummaryBox').style.display = 'none';
        scanning = true;
        selectedCode = null;
      });
  }

  function onScanSuccess(decodedText) {
    selectCode(decodedText);
  }

  const html5QrCode = new Html5Qrcode("reader");
  html5QrCode.start(
    { facingMode: "environment" },
    { fps: 10, qrbox: 250 },
    onScanSuccess
  ).catch(() => {});
</script>

<%- include('partials/footer') %>