<%- include('partials/header') %>

<h3 class="mb-2">🎬 <%= video.title %></h3>
<p class="text-muted mb-4">
  <%= video.Session.Subject.name %> - <%= video.Session.Center.name %> - حصة رقم <%= video.Session.lesson_number %>
</p>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="mb-3">إضافة فيديو جديد لهذا الدرس</h6>
    <form action="/admin/videos/<%= video.id %>/add-part" method="POST" enctype="multipart/form-data" class="row g-2">
      <div class="col-md-3">
        <select name="category" class="form-select" required>
          <option value="explanation">فيديو الشرح</option>
          <option value="questions">فيديو الأسئلة</option>
          <option value="homework_solution">فيديو حل الواجب</option>
        </select>
      </div>
      <div class="col-md-2">
        <input type="number" name="order_index" class="form-control" placeholder="الترتيب" value="1" min="1" required>
      </div>
      <div class="col-md-2">
        <select name="source_type" id="sourceType" class="form-select" onchange="toggleSource()">
          <option value="link">لينك</option>
          <option value="upload">رفع ملف</option>
        </select>
      </div>
      <div class="col-md-3" id="linkInputBox">
        <input type="text" name="video_url" class="form-control" placeholder="لينك الفيديو">
      </div>
      <div class="col-md-3" id="uploadInputBox" style="display:none;">
        <input type="file" name="video_file" class="form-control" accept="video/*">
      </div>
      <div class="col-md-2">
        <input type="number" name="duration_seconds" class="form-control" placeholder="المدة بالثواني" required>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-success w-100">إضافة</button>
      </div>
    </form>
    <p class="text-muted small mt-2">💡 لو فيه أكتر من لينك لنفس النوع، ضيفهم بترتيب مختلف (1, 2, 3...).</p>
  </div>
</div>

<% ['explanation', 'questions', 'homework_solution'].forEach(cat => { %>
  <% const labels = { explanation: '📖 فيديو الشرح', questions: '❓ فيديو الأسئلة', homework_solution: '✅ فيديو حل الواجب' }; %>
  <div class="card shadow-sm mb-3">
    <div class="card-body">
      <h6 class="mb-3"><%= labels[cat] %></h6>
      <% const parts = videoParts.filter(p => p.category === cat); %>
      <% if (parts.length === 0) { %>
        <p class="text-muted small">لا يوجد فيديو من هذا النوع حتى الآن</p>
      <% } %>
      <% if (parts.length > 0) { %>
      <table class="table table-sm">
        <tbody>
          <% parts.forEach(p => { %>
            <tr>
              <td>الجزء <%= p.order_index %></td>
              <td class="small">
                <% if (p.source_type === 'link') { %>
                  <a href="<%= p.video_url %>" target="_blank" class="text-decoration-none">🔗 لينك خارجي</a>
                <% } else { %>📁 ملف مرفوع<% } %>
              </td>
              <td><%= Math.floor(p.duration_seconds / 60) %>:<%= String(p.duration_seconds % 60).padStart(2, '0') %></td>
              <td>
                <form action="/admin/videos/part/<%= p.id %>/delete" method="POST" onsubmit="return confirm('متأكد من الحذف؟')">
                  <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      <% } %>
    </div>
  </div>
<% }) %>

<div class="card shadow-sm mb-3">
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <h6 class="mb-1">🔐 إدارة وصول المشاهدة</h6>
      <p class="text-muted small mb-0">نقل التحكم في الحصص والطلاب المسموح لهم إلى صفحة مخصصة.</p>
    </div>
    <a href="/admin/videos/<%= video.id %>/access" class="btn btn-primary">الذهاب إلى صفحة الوصول</a>
  </div>
</div>

<div class="card shadow-sm mb-3">
  <div class="card-body">
    <h6 class="mb-3">🏫 الحصص المسموح لها بمشاهدة هذا الفيديو</h6>

    <div class="d-flex flex-wrap gap-2 mb-3">
      <% if (videoSessions.length === 0) { %>
        <span class="text-muted small">لا توجد حصص مرتبطة (الفيديو مرئي للجميع!)</span>
      <% } %>
      <% videoSessions.forEach(vs => { %>
        <div class="d-flex align-items-center gap-1 p-2 rounded" style="background:#EEF0FB;font-size:0.8rem;">
          <span><strong><%= vs.Session?.Subject?.name %></strong> - <%= vs.Session?.Center?.name %> (حصة <%= vs.Session?.lesson_number %>)</span>
          <form action="/admin/videos/<%= video.id %>/remove-session/<%= vs.SessionId %>" method="POST">
            <button class="btn btn-sm" style="padding:1px 6px;background:#FEE2E2;color:#B91C1C;font-size:0.65rem;">✕</button>
          </form>
        </div>
      <% }) %>
    </div>

    <form action="/admin/videos/<%= video.id %>/add-session" method="POST" class="d-flex gap-2">
      <select name="session_id" class="form-select form-select-sm" style="max-width:350px;" required>
        <option value="">-- إضافة حصة جديدة --</option>
        <% allSessions.forEach(s => { %>
          <% const alreadyAdded = videoSessions.some(vs => vs.SessionId === s.id); %>
          <% if (!alreadyAdded) { %>
            <option value="<%= s.id %>"><%= s.Subject?.name %> - <%= s.Center?.name %> (حصة <%= s.lesson_number %> | سيريال <%= s.serial_number %>)</option>
          <% } %>
        <% }) %>
      </select>
      <button class="btn btn-sm btn-primary">+ إضافة</button>
    </form>
  </div>
</div>

<div class="card shadow-sm mb-3">
  <div class="card-body">
    <h6 class="mb-3">👤 وصول فردي لطلاب بعينهم (خارج المجموعات المسموح بها)</h6>

    <div class="d-flex flex-wrap gap-2 mb-3">
      <% if (studentAccesses.length === 0) { %>
        <span class="text-muted small">لا يوجد طلاب بوصول فردي</span>
      <% } %>
      <% studentAccesses.forEach(sa => { %>
        <div class="d-flex align-items-center gap-1 p-2 rounded" style="background:#D1FAE5;font-size:0.8rem;">
          <span><strong><%= sa.Student?.name %></strong> (<%= sa.Student?.student_code %>)</span>
          <span class="text-muted" style="font-size:0.7rem;"> - <%= sa.Student?.Subject?.name %> - <%= sa.Student?.Center?.name %></span>
          <form action="/admin/videos/<%= video.id %>/remove-student-access/<%= sa.id %>" method="POST">
            <button class="btn btn-sm" style="padding:1px 6px;background:#FEE2E2;color:#B91C1C;font-size:0.65rem;">✕</button>
          </form>
        </div>
      <% }) %>
    </div>

    <form action="/admin/videos/<%= video.id %>/add-student-access" method="POST" class="d-flex gap-2">
      <input type="text" name="student_code" class="form-control form-control-sm" style="max-width:200px;"
        placeholder="كود الطالب (STU-XXXXX)" required>
      <button class="btn btn-sm btn-success">+ إضافة طالب</button>
    </form>
  </div>
</div>

<script>
  function toggleSource() {
    const type = document.getElementById('sourceType').value;
    document.getElementById('linkInputBox').style.display = type === 'link' ? 'block' : 'none';
    document.getElementById('uploadInputBox').style.display = type === 'upload' ? 'block' : 'none';
  }
</script>

<%- include('partials/footer') %>