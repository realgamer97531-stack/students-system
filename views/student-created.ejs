<%- include('partials/header') %>
  <div class="container py-5 text-center">
    <div class="card shadow-sm mx-auto p-4" style="max-width: 450px;">
      <h3 class="text-success mb-3">✅ تم تسجيل الطالب بنجاح</h3>
      <h5 class="mb-3"><%= student.name %></h5>
      <p class="text-muted">كود الطالب: <strong><%= student.student_code %></strong></p>
      <% if (typeof attendanceNote !== 'undefined' && attendanceNote) { %>
        <div class="alert alert-info text-start">
          <%= attendanceNote %>
        </div>
      <% } %>

      <img src="<%= qrCodeImage %>" alt="QR Code" class="img-fluid mb-3" style="max-width: 250px; margin: auto;">

      <a href="/students/new" class="btn btn-primary w-100">تسجيل طالب آخر</a>
      <a href="/students" class="btn btn-outline-secondary w-100 mt-2">عرض كل الطلاب</a>
    </div>
  </div>
<%- include('partials/footer') %>