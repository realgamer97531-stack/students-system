<%- include('partials/header') %>

<h3 class="mb-2">⚠️ طلاب محتاجين متابعة</h3>
<p class="text-muted mb-4">نظام متقدم لمتابعة أداء الطلاب مع تحليل شامل للمخاطر</p>

<style>
  .severity-critical { background-color: #fee2e2; border-left: 4px solid #dc2626; }
  .severity-warning { background-color: #fef3c7; border-left: 4px solid #f59e0b; }
  .severity-caution { background-color: #e0f2fe; border-left: 4px solid #0284c7; }
  
  .risk-badge { 
    font-size: 0.85rem; 
    font-weight: bold;
    padding: 4px 8px;
    border-radius: 4px;
  }
  .risk-critical { background: #dc2626; color: white; }
  .risk-warning { background: #f59e0b; color: white; }
  .risk-caution { background: #0284c7; color: white; }

  .student-row { cursor: pointer; transition: all 0.3s ease; }
  .student-row:hover { transform: translateX(4px); }
  
  .details-section { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
  .details-section.open { max-height: 500px; }
  
  .stat-mini { display: inline-block; margin: 4px 8px 4px 0; padding: 4px 8px; background: #f3f4f6; border-radius: 4px; font-size: 0.85rem; }
  .exam-item { background: #f9fafb; padding: 8px; margin: 4px 0; border-radius: 4px; font-size: 0.85rem; }
  
  .badge-flag {
    display: inline-block;
    margin: 2px 4px;
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: bold;
  }
  .badge-critical { background: #fee2e2; color: #991b1b; }
  .badge-warning { background: #fef3c7; color: #92400e; }
</style>

<div class="card shadow-sm">
  <div class="card-body">
    <% if (result.length === 0) { %>
      <div class="alert alert-success mb-0">🎉 مفيش حد محتاج متابعة دلوقتي - وضع ممتاز!</div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th style="width: 5%;">مستوى الخطورة</th>
              <th style="width: 8%;">الكود</th>
              <th style="width: 12%;">الاسم</th>
              <th style="width: 10%;">السنتر</th>
              <th style="width: 10%;">المادة</th>
              <th style="width: 8%;">الرصيد</th>
              <th style="width: 47%;">الأسباب والتفاصيل</th>
            </tr>
          </thead>
          <tbody>
            <% result.forEach((r, index) => { %>
              <tr class="student-row severity-<%= r.severity %>" onclick="toggleDetails(this, <%= index %>)">
                <td>
                  <span class="risk-badge risk-<%= r.severity %>">
                    <% if (r.severity === 'critical') { %>🔴 حرج<% } 
                       else if (r.severity === 'warning') { %>🟠 تحذير<% } 
                       else { %>🟡 تنبيه<% } %>
                  </span>
                  <div style="font-size: 0.75rem; color: #666; margin-top: 2px;">نقاط: <%= r.riskScore %></div>
                </td>
                <td><strong><%= r.student.student_code %></strong></td>
                <td>
                  <a href="/students/<%= r.student.id %>" style="text-decoration: none; color: inherit;">
                    <strong><%= r.student.name %></strong>
                  </a>
                  <br>
                  <small class="text-muted">آخر حضور: <%= r.lastAttendance %></small>
                </td>
                <td><%= r.student.Center.name %></td>
                <td><%= r.student.Subject.name %></td>
                <td>
                  <% if (r.student.balance < 100) { %>
                    <span class="badge bg-danger"><%= r.student.balance %> ج</span>
                  <% } else { %>
                    <span class="badge bg-success"><%= r.student.balance %> ج</span>
                  <% } %>
                </td>
                <td>
                  <% r.reasons.forEach(reason => { %>
                    <div style="margin: 2px 0; font-size: 0.9rem;"><%= reason %></div>
                  <% }) %>
                </td>
              </tr>

              <!-- صف التفاصيل المخفي -->
              <tr class="details-row" id="details-<%= index %>" style="display: none;">
                <td colspan="7" class="p-3">
                  <div class="row">
                    <!-- قسم الإحصائيات -->
                    <div class="col-md-4">
                      <h6 class="fw-bold mb-2">📊 الإحصائيات</h6>
                      <div class="stat-mini">
                        📅 حضور: <strong><%= r.statistics.attendanceRate %>%</strong>
                      </div>
                      <div class="stat-mini">
                        ✅ واجبات: <strong><%= r.statistics.homeworkQuality %>%</strong>
                      </div>
                      <div class="stat-mini">
                        📈 متوسط امتحانات: <strong><%= r.statistics.averageExamScore %>%</strong>
                      </div>
                    </div>

                    <!-- قسم الأعلام والتحذيرات -->
                    <div class="col-md-4">
                      <h6 class="fw-bold mb-2">🚩 الأعلام</h6>
                      <% if (r.flags.lowBalance) { %>
                        <span class="badge-flag badge-critical">💳 رصيد منخفض</span>
                      <% } %>
                      <% if (r.flags.absentSessions === true) { %>
                        <span class="badge-flag badge-critical">🔴 غياب متكرر</span>
                      <% } else if (r.flags.absentSessions === 'warning') { %>
                        <span class="badge-flag badge-warning">🟡 غياب واحد</span>
                      <% } %>
                      <% if (r.flags.poorHomework === true) { %>
                        <span class="badge-flag badge-critical">🟠 واجبات ضعيفة</span>
                      <% } else if (r.flags.poorHomework === 'warning') { %>
                        <span class="badge-flag badge-warning">🟡 واجب ضعيف</span>
                      <% } %>
                      <% if (r.flags.unfinalizedExams) { %>
                        <span class="badge-flag badge-warning">📝 امتحانات لم تُصحح</span>
                      <% } %>
                      <% if (r.flags.lowExamScores) { %>
                        <span class="badge-flag badge-critical">📊 علامات منخفضة</span>
                      <% } %>
                      <% if (r.flags.warnings) { %>
                        <span class="badge-flag badge-critical">⚠️ تنبيهات معلقة</span>
                      <% } %>
                    </div>

                    <!-- قسم آخر امتحانات -->
                    <div class="col-md-4">
                      <h6 class="fw-bold mb-2">📋 آخر امتحانات</h6>
                      <% if (r.statistics.recentExams.length > 0) { %>
                        <% r.statistics.recentExams.forEach(exam => { %>
                          <div class="exam-item">
                            حصة #<strong><%= exam.lesson %></strong>: 
                            <span class="<%= exam.percentage >= 60 ? 'text-success' : exam.percentage >= 40 ? 'text-warning' : 'text-danger' %>" style="font-weight: bold;">
                              <%= exam.score %>/<%= exam.maxScore %> (<%= exam.percentage %>%)
                            </span>
                          </div>
                        <% }) %>
                      <% } else { %>
                        <small class="text-muted">لا توجد امتحانات</small>
                      <% } %>
                    </div>
                  </div>

                  <!-- قسم التنبيهات المعلقة -->
                  <% if (r.warnings && r.warnings.length > 0) { %>
                    <div class="mt-3 pt-3 border-top">
                      <h6 class="fw-bold text-danger">⚠️ التنبيهات المعلقة</h6>
                      <ul class="mb-0 small">
                        <% r.warnings.forEach(w => { %>
                          <li><strong><%= w.reason %></strong> <span class="text-muted">(<%= new Date(w.createdAt).toLocaleDateString('ar-EG') %>)</span></li>
                        <% }) %>
                      </ul>
                    </div>
                  <% } %>

                  <!-- أزرار الإجراءات السريعة -->
                  <div class="mt-3 pt-3 border-top">
                    <button class="btn btn-sm btn-primary" onclick="alert('رسالة: سيتم إضافة هذه الميزة قريباً')">💬 إرسال رسالة</button>
                    <button class="btn btn-sm btn-warning" onclick="alert('جدولة: سيتم إضافة هذه الميزة قريباً')">📅 جدولة متابعة</button>
                    <button class="btn btn-sm btn-info" onclick="window.location.href='/students/<%= r.student.id %>'">👁️ عرض الملف</button>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script>
function toggleDetails(row, index) {
  const detailsRow = document.getElementById(`details-${index}`);
  if (detailsRow.style.display === 'none') {
    detailsRow.style.display = 'table-row';
    row.classList.add('fw-bold');
  } else {
    detailsRow.style.display = 'none';
    row.classList.remove('fw-bold');
  }
}
</script>

<%- include('partials/footer') %>