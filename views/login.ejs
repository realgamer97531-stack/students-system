<!DOCTYPE html>
<html lang="ar" dir="rtl" id="htmlRoot">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Studyisfunny | تسجيل الدخول</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --sf-primary: #4338CA;
      --sf-primary-dark: #312E81;
      --sf-accent: #14B8A6;
      --sf-bg: #F5F6FB;
      --sf-text: #1E1B2E;
      --sf-muted: #6B7280;
      --sf-card-bg: #FFFFFF;
      --sf-input-border: #E2E4F3;
    }

    /* Dark Mode Variables */
    [data-theme="dark"] {
      --sf-primary: #6366F1;
      --sf-primary-dark: #4F46E5;
      --sf-accent: #14B8A6;
      --sf-bg: #0F172A;
      --sf-text: #E2E8F0;
      --sf-muted: #94A3B8;
      --sf-card-bg: #1E293B;
      --sf-input-border: #334155;
    }

    * { font-family: 'Cairo', sans-serif; box-sizing: border-box; }
    body {
      min-height: 100vh;
      display: flex; 
      align-items: center;
      position: relative;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 15% 20%, rgba(20, 184, 166, 0.25), transparent 40%),
        radial-gradient(circle at 85% 80%, rgba(255, 255, 255, 0.12), transparent 45%),
        linear-gradient(135deg, var(--sf-primary) 0%, var(--sf-primary-dark) 100%);
      color: var(--sf-text);
      transition: background 0.3s ease;
    }

    [data-theme="dark"] body {
      background:
        radial-gradient(circle at 15% 20%, rgba(20, 184, 166, 0.18), transparent 40%),
        radial-gradient(circle at 85% 80%, rgba(99, 102, 241, 0.15), transparent 45%),
        linear-gradient(135deg, #1E293B 0%, #0F172A 100%);
    }

    .login-container {
      display: flex;
      gap: 20px;
      align-items: center;
      justify-content: center;
    }

    .login-card {
      border: none; 
      border-radius: 22px;
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
      overflow: hidden;
      background: var(--sf-card-bg);
      color: var(--sf-text);
      animation: sf-login-in 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @keyframes sf-login-in {
      from { opacity: 0; transform: translateY(14px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .logo-mark {
      width: 60px; 
      height: 60px; 
      margin: 0 auto 12px;
      background: linear-gradient(135deg, var(--sf-accent), var(--sf-primary));
      border-radius: 18px;
      display: flex; 
      align-items: center; 
      justify-content: center;
      color: #fff; 
      font-weight: 800; 
      font-size: 1.7rem;
      box-shadow: 0 10px 24px rgba(20, 184, 166, 0.35);
    }

    .logo-text { 
      text-align: center; 
      font-weight: 800; 
      font-size: 1.45rem; 
      color: var(--sf-text); 
      margin-bottom: 4px; 
      letter-spacing: -0.2px;
    }
    .logo-text span { color: var(--sf-accent); }

    .form-control { 
      border-radius: 11px; 
      padding: 0.75rem 1rem;
      background: var(--sf-card-bg);
      color: var(--sf-text);
      border: 1px solid var(--sf-input-border);
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    .form-control:hover { border-color: var(--sf-primary); }

    .form-control:focus {
      background: var(--sf-card-bg);
      color: var(--sf-text);
      border-color: var(--sf-primary);
      box-shadow: 0 0 0 3px rgba(67, 56, 202, 0.12);
    }

    .form-label {
      color: var(--sf-text);
    }

    .btn-login {
      background: linear-gradient(135deg, var(--sf-primary), var(--sf-primary-dark));
      border: none; 
      border-radius: 11px; 
      font-weight: 700; 
      padding: 0.75rem;
      color: white;
      box-shadow: 0 8px 20px rgba(67, 56, 202, 0.3);
      transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s ease;
    }

    .btn-login:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 26px rgba(67, 56, 202, 0.4);
      color: white;
    }
    .btn-login:active { transform: translateY(0); }

    .text-muted { color: var(--sf-muted) !important; }
    .alert { background: var(--sf-card-bg); color: var(--sf-text); border-color: var(--sf-input-border); border-radius: 10px; }

    /* Language toggle classes */
    .ar-only { display: inline; }
    .en-only { display: none; }

    [lang="en"] .ar-only { display: none !important; }
    [lang="en"] .en-only { display: inline !important; }

    .theme-toggle {
      position: absolute;
      top: 20px;
      left: 20px;
      background: rgba(255,255,255,0.2);
      border: none;
      border-radius: 50%;
      width: 45px;
      height: 45px;
      color: white;
      cursor: pointer;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(6px);
      transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .theme-toggle:hover {
      background: rgba(255,255,255,0.3);
      transform: translateY(-2px);
    }

    [data-theme="dark"] .theme-toggle {
      background: rgba(30,41,59,0.4);
    }

    .language-toggle {
      position: absolute;
      top: 20px;
      left: 80px;
      background: rgba(255,255,255,0.2);
      border: none;
      border-radius: 50%;
      width: 45px;
      height: 45px;
      color: white;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: bold;
      display: flex;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(6px);
      transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .language-toggle:hover {
      background: rgba(255,255,255,0.3);
      transform: translateY(-2px);
    }

    [data-theme="dark"] .language-toggle {
      background: rgba(30,41,59,0.4);
    }
  </style>
</head>
<body onload="initializeTheme(); applyLanguageDisplay();">
  <button class="theme-toggle" title="Toggle Dark Mode" onclick="toggleDarkMode()">
    <span class="ar-only">🌙</span>
    <span class="en-only" style="display:none;">🌙</span>
  </button>
  <button class="language-toggle" title="تغيير اللغة" onclick="toggleLanguage()">
    <span class="ar-only">EN</span>
    <span class="en-only" style="display:none;">AR</span>
  </button>

  <div class="container">
    <div class="card login-card mx-auto p-4" style="max-width: 400px;">
      <div class="card-body">
        <div class="logo-mark">S</div>
        <div class="logo-text">Study<span>is</span>funny</div>
        <p class="text-center text-muted small mb-4">
          <span class="ar-only">نظام متابعة الطلاب</span>
          <span class="en-only" style="display:none;">Student Tracking System</span>
        </p>

        <% if (error) { %><div class="alert alert-danger small"><%= error %></div><% } %>

        <form action="/login" method="POST">
          <div class="mb-3">
            <label class="form-label small fw-bold">
              <span class="ar-only">اليوزرنيم</span>
              <span class="en-only" style="display:none;">Username</span>
            </label>
            <input type="text" name="username" class="form-control" required autofocus>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-bold">
              <span class="ar-only">الباسورد</span>
              <span class="en-only" style="display:none;">Password</span>
            </label>
            <input type="password" name="password" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-login text-white w-100">
            <span class="ar-only">دخول</span>
            <span class="en-only" style="display:none;">Login</span>
          </button>
        </form>
      </div>
    </div>
  </div>

  <script>
    function initializeTheme() {
      const theme = localStorage.getItem('theme') || 'light';
      const lang = localStorage.getItem('language') || 'ar';
      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.setAttribute('lang', lang);
      document.documentElement.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
    }

    function applyLanguageDisplay() {
      const lang = localStorage.getItem('language') || 'ar';
      const arElements = document.querySelectorAll('.ar-only');
      const enElements = document.querySelectorAll('.en-only');

      if (lang === 'ar') {
        arElements.forEach(el => el.style.display = '');
        enElements.forEach(el => el.style.display = 'none');
      } else {
        arElements.forEach(el => el.style.display = 'none');
        enElements.forEach(el => el.style.display = '');
      }
    }

    function toggleDarkMode() {
      const current = localStorage.getItem('theme') || 'light';
      const newTheme = current === 'light' ? 'dark' : 'light';
      localStorage.setItem('theme', newTheme);
      document.documentElement.setAttribute('data-theme', newTheme);
    }

    function toggleLanguage() {
      const current = localStorage.getItem('language') || 'ar';
      const newLang = current === 'ar' ? 'en' : 'ar';
      localStorage.setItem('language', newLang);
      document.documentElement.setAttribute('lang', newLang);
      document.documentElement.setAttribute('dir', newLang === 'ar' ? 'rtl' : 'ltr');
      applyLanguageDisplay();
    }

    // Apply theme immediately before render to prevent flash
    initializeTheme();
  </script>
</body>
</html>