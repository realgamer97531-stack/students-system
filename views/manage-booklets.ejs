<%- include('partials/header') %>

<h3 class="mb-4">📚 إدارة البوكليتس</h3>

<div class="card shadow-sm mb-4">
  <div class="card-body">
    <h6 class="mb-3">إضافة بوكليت جديد</h6>
    <form action="/admin/booklets/add" method="POST" class="row g-2">
      <div class="col-md-2">
        <input type="text" name="name" class="form-control" placeholder="اسم البوكليت" required>
      </div>
      <div class="col-md-2">
        <select name="subject_id" class="form-select" required>
          <option value="">-- المادة --</option>
          <% subjects.forEach(s => { %><option value="<%= s.id %>"><%= s.name %></option><% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <input type="number" name="print_price" step="0.5" class="form-control" placeholder="سعر الطباعة" required>
      </div>
      <div class="col-md-2">
        <input type="number" name="sell_price" step="0.5" class="form-control" placeholder="سعر البيع" required>
      </div>
      <div class="col-md-1">
        <input type="number" name="stock_count" class="form-control" placeholder="الكمية" required>
      </div>
      <div class="col-md-1">
        <input type="number" name="order_index" class="form-control" placeholder="الترتيب" value="1">
      </div>
      <div class="col-md-2">
        <button class="btn btn-primary w-100">إضافة</button>
      </div>
    </form>
  </div>
</div>

<div class="row g-3">
  <% booklets.forEach(b => { %>
    <div class="col-md-4">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between mb-2">
            <strong><%= b.name %></strong>
            <span class="badge <%= b.is_active ? 'bg-success' : 'bg-secondary' %>">
              <%= b.is_active ? 'نشط' : 'متوقف' %>
            </span>
          </div>
          <p class="small text-muted mb-2">📚 <%= b.Subject.name %></p>

          <div class="row g-1 mb-2 text-center">
            <div class="col-4">
              <div class="p-2 rounded" style="background:#EEF0FB;">
                <div class="small text-muted">سعر الطباعة</div>
                <div class="fw-bold" style="color:#4338CA;"><%= b.print_price %> ج</div>
              </div>
            </div>
            <div class="col-4">
              <div class="p-2 rounded" style="background:#D1FAE5;">
                <div class="small text-muted">سعر البيع</div>
                <div class="fw-bold text-success"><%= b.sell_price %> ج</div>
              </div>
            </div>
            <div class="col-4">
              <div class="p-2 rounded" style="background:#FEF3C7;">
                <div class="small text-muted">هامش الربح</div>
                <div class="fw-bold text-warning"><%= (b.sell_price - b.print_price).toFixed(1) %> ج</div>
              </div>
            </div>
          </div>

          <div class="d-flex justify-content-between small mb-3">
            <span>الكمية المتاحة: <strong><%= b.stock_count %></strong></span>
            <span>إجمالي التكلفة: <strong><%= (b.print_price * b.stock_count).toFixed(0) %> ج</strong></span>
          </div>

          <form action="/admin/booklets/<%= b.id %>/edit" method="POST" class="row g-1">
            <div class="col-6">
              <input type="number" name="sell_price" class="form-control form-control-sm" value="<%= b.sell_price %>" placeholder="سعر البيع">
            </div>
            <div class="col-6">
              <input type="number" name="stock_count" class="form-control form-control-sm" value="<%= b.stock_count %>" placeholder="الكمية">
            </div>
            <input type="hidden" name="name" value="<%= b.name %>">
            <input type="hidden" name="print_price" value="<%= b.print_price %>">
            <input type="hidden" name="order_index" value="<%= b.order_index %>">
            <div class="col-6 mt-1">
              <div class="form-check">
                <input type="checkbox" name="is_active" class="form-check-input" <%= b.is_active ? 'checked' : '' %>>
                <label class="form-check-label small">نشط</label>
              </div>
            </div>
            <div class="col-6 mt-1">
              <button class="btn btn-sm btn-outline-primary w-100">حفظ</button>
            </div>
          </form>

          <form action="/admin/booklets/<%= b.id %>/delete" method="POST" onsubmit="return confirm('حذف؟')" class="mt-1">
            <button class="btn btn-sm btn-outline-danger w-100">حذف</button>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<%- include('partials/footer') %>